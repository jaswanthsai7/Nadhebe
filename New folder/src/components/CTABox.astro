---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  ctaLabel: string;
  ctaHref: string;
  variant?: 'default' | 'inverted';
}
const { eyebrow, title, description, ctaLabel, ctaHref, variant = 'default' } = Astro.props;
---

<div
  class={`not-prose rounded-card border p-6 sm:p-8 ${
    variant === 'inverted'
      ? 'border-transparent bg-ink text-white dark:bg-white dark:text-ink'
      : 'border-border bg-surface2 dark:border-border-dark dark:bg-surface2-dark'
  }`}
>
  <div class="flex flex-col items-start gap-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      {eyebrow && (
        <p class={`mb-1.5 text-meta font-sans font-semibold uppercase tracking-wider ${variant === 'inverted' ? 'opacity-70' : 'text-muted dark:text-muted-dark'}`}>
          {eyebrow}
        </p>
      )}
      <p class="text-body font-semibold">{title}</p>
      {description && <p class={`mt-1.5 max-w-md text-meta font-sans leading-relaxed ${variant === 'inverted' ? 'opacity-80' : 'text-ink2 dark:text-ink2-dark'}`}>{description}</p>}
    </div>
    <a
      href={ctaHref}
      class={variant === 'inverted' ? 'btn bg-white text-ink hover:opacity-90 dark:bg-ink dark:text-white shrink-0' : 'btn-primary shrink-0'}
    >
      {ctaLabel}
    </a>
  </div>
</div>
