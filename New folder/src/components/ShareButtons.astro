---
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="flex items-center gap-2" data-share-buttons>
  <a
    href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on X"
    class="flex h-9 w-9 items-center justify-center rounded-control border border-border text-ink2 transition-colors hover:bg-hover dark:border-border-dark dark:text-ink2-dark dark:hover:bg-hover-dark"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
      <path d="M18.9 2H22l-7.6 8.7L23 22h-7l-5.5-7.2L4.2 22H1l8.1-9.3L1 2h7.2l5 6.6L18.9 2Zm-1.2 18h1.7L6.4 4H4.6l13.1 16Z"></path>
    </svg>
  </a>
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on LinkedIn"
    class="flex h-9 w-9 items-center justify-center rounded-control border border-border text-ink2 transition-colors hover:bg-hover dark:border-border-dark dark:text-ink2-dark dark:hover:bg-hover-dark"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
      <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4.02 0 4.76 2.65 4.76 6.1V21H18v-5.6c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96V21H10V9Z"></path>
    </svg>
  </a>
  <button
    type="button"
    data-copy-link={url}
    aria-label="Copy link"
    class="flex h-9 w-9 items-center justify-center rounded-control border border-border text-ink2 transition-colors hover:bg-hover dark:border-border-dark dark:text-ink2-dark dark:hover:bg-hover-dark"
  >
    <svg data-copy-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4">
      <path d="M10 13a5 5 0 0 0 7.5.5l2-2a5 5 0 0 0-7-7l-1.1 1.1"></path>
      <path d="M14 11a5 5 0 0 0-7.5-.5l-2 2a5 5 0 0 0 7 7l1.1-1.1"></path>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.copyLink!;
      await navigator.clipboard.writeText(url);
      const icon = btn.querySelector('[data-copy-icon]');
      if (icon) {
        icon.innerHTML = '<path d="M20 6 9 17l-5-5"></path>';
        setTimeout(() => {
          icon.innerHTML =
            '<path d="M10 13a5 5 0 0 0 7.5.5l2-2a5 5 0 0 0-7-7l-1.1 1.1"></path><path d="M14 11a5 5 0 0 0-7.5-.5l-2 2a5 5 0 0 0 7 7l1.1-1.1"></path>';
        }, 1600);
      }
    });
  });
</script>
