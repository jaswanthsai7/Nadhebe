---
interface Props {
  score: number;
  size?: number; // Outer container size in pixels, default is 80
}

const { score, size = 80 } = Astro.props;

// Restrict rating to [0, 10] range
const rating = Math.min(10, Math.max(0, score));

// Formatted rating string
const formattedScore = rating.toFixed(1);

// Arc radius
const r = 32;
// Circumference
const circumference = 2 * Math.PI * r; // ~201.06

// Dash offset based on rating percentage
const percentage = rating / 10;
const targetOffset = circumference * (1 - percentage);
---

<div 
  class="verdict-gauge-wrapper select-none shrink-0" 
  style={`width: ${size}px; height: ${size}px;`}
  role="img"
  aria-label={`Verdict score: ${formattedScore} out of 10`}
>
  <svg viewBox="0 0 80 80" class="w-full h-full">
    <!-- Background track circle -->
    <circle
      cx="40"
      cy="40"
      r={r}
      class="stroke-border dark:stroke-border-dark fill-none"
      stroke-width="3"
    />
    <!-- Active animated arc -->
    <circle
      cx="40"
      cy="40"
      r={r}
      class="gauge-arc stroke-rating-gold fill-none"
      stroke-width="3"
      stroke-linecap="round"
      stroke-dasharray={circumference}
      stroke-dashoffset={targetOffset}
      transform="rotate(-90 40 40)"
      style={`--circumference: ${circumference}; --target-offset: ${targetOffset};`}
    />
    <!-- Centered Score Text -->
    <text
      x="40"
      y="38"
      text-anchor="middle"
      class="fill-ink dark:fill-ink-dark font-mono text-[18px] font-semibold"
    >
      {formattedScore}
    </text>
    <!-- Out-of-10 Sub-label (minimum 12px for accessibility guidelines) -->
    <text
      x="40"
      y="54"
      text-anchor="middle"
      class="fill-muted font-mono text-[12px] font-medium"
    >
      /10
    </text>
  </svg>
</div>

<script>
  function initVerdictGauges() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wrappers = document.querySelectorAll('.verdict-gauge-wrapper');

    if (!prefersReduced) {
      wrappers.forEach(wrapper => {
        const arc = wrapper.querySelector('.gauge-arc') as SVGGeometryElement | null;
        if (arc) {
          const circ = arc.style.getPropertyValue('--circumference');
          if (circ) {
            arc.style.strokeDashoffset = circ;
          }
        }
      });
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const arc = entry.target.querySelector('.gauge-arc') as SVGGeometryElement | null;
          if (arc && !prefersReduced) {
            arc.style.strokeDashoffset = ''; // Clear inline styles to let CSS keyframes run
            arc.classList.add('animate-sweep');
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    wrappers.forEach(wrapper => {
      observer.observe(wrapper);
    });
  }

  // Initial load
  initVerdictGauges();

  // Support Astro View Transitions if enabled
  document.addEventListener('astro:page-load', initVerdictGauges);
</script>

<style>
  @keyframes gauge-sweep {
    from {
      stroke-dashoffset: var(--circumference);
    }
    to {
      stroke-dashoffset: var(--target-offset);
    }
  }

  .gauge-arc.animate-sweep {
    animation: gauge-sweep 0.6s ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .gauge-arc {
      animation: none !important;
      stroke-dashoffset: var(--target-offset) !important;
    }
  }
</style>
