---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Contact details for inquiries, feedback, and collaboration opportunities."
>
  <div class="mx-auto max-w-3xl px-24 py-48 sm:py-64">
    <article class="prose-article">
      <h1 class="font-display text-h1 font-bold text-ink dark:text-ink-dark mb-24">Get in Touch</h1>
      <p class="text-body text-ink2 dark:text-ink2-dark">
        For comments on articles, collaboration opportunities, or questions regarding tutorials, feel free to reach out directly through our channels.
      </p>

      <div class="card p-24 my-32 space-y-24">
        <div>
          <p class="text-meta font-sans font-semibold text-muted dark:text-muted-dark uppercase tracking-wider">General & Editorial Inquiries</p>
          <p class="mt-4">
            <a href="mailto:hello@example.com" class="text-body font-semibold text-accent hover:text-accent-dark transition-colors">hello@example.com</a>
          </p>
        </div>
        
        <div>
          <p class="text-meta font-sans font-semibold text-muted dark:text-muted-dark uppercase tracking-wider">Social Channels</p>
          <div class="flex gap-16 mt-8">
            <a
              href="https://twitter.com/example"
              target="_blank"
              rel="noopener noreferrer"
              class="text-body font-semibold text-ink hover:text-accent dark:text-ink-dark dark:hover:text-accent transition-colors"
            >
              Twitter/X →
            </a>
            <a
              href="https://github.com/example"
              target="_blank"
              rel="noopener noreferrer"
              class="text-body font-semibold text-ink hover:text-accent dark:text-ink-dark dark:hover:text-accent transition-colors"
            >
              GitHub →
            </a>
          </div>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
