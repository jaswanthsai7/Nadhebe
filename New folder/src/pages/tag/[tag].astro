---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllArticles, getArticleUrl } from '../../utils/content';
import VerdictGauge from '../../components/VerdictGauge.astro';

export async function getStaticPaths() {
  const allArticles = await getAllArticles();
  const tagMap = new Map<string, { tagName: string; posts: any[] }>();
  
  allArticles.forEach(post => {
    if (post.data.tags) {
      post.data.tags.forEach(tag => {
        const slug = tag.toLowerCase().replace(/\s+/g, '-');
        if (!tagMap.has(slug)) {
          tagMap.set(slug, { tagName: tag, posts: [] });
        }
        tagMap.get(slug)!.posts.push(post);
      });
    }
    if (post.data.topic) {
      const slug = post.data.topic.toLowerCase().replace(/\s+/g, '-');
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { tagName: post.data.topic, posts: [] });
      }
      if (!tagMap.get(slug)!.posts.some(p => p.slug === post.slug)) {
        tagMap.get(slug)!.posts.push(post);
      }
    }
  });

  return Array.from(tagMap.entries()).map(([slug, { tagName, posts }]) => ({
    params: { tag: slug },
    props: { tagName, posts },
  }));
}

const { tagName, posts } = Astro.props;
---

<BaseLayout
  title={`Articles on ${tagName}`}
  description={`Browse technical articles, tools comparisons, reviews and prompts for ${tagName}.`}
>
  <div class="mx-auto max-w-6xl px-24 py-48 sm:py-64">
    <div class="border-b border-border dark:border-border-dark pb-16 mb-24">
      <p class="text-meta font-sans font-semibold text-accent dark:text-accent-dark uppercase tracking-wider mb-8">Tag Hub</p>
      <h1 class="font-display text-h1 sm:text-display font-bold text-ink dark:text-ink-dark leading-tight">Topic: {tagName}</h1>
      <p class="text-body text-ink2 dark:text-ink2-dark mt-16 max-w-md">
        Explore all our posts matching the keyword or topic cluster: <code class="bg-code dark:bg-code-dark px-8 py-2 rounded font-mono text-meta text-ink dark:text-ink-dark">{tagName}</code>.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-24">
      {posts.map(post => (
        <a
          href={getArticleUrl(post)}
          class="card group flex flex-col overflow-hidden p-0 h-full"
        >
          <div class="aspect-video w-full overflow-hidden relative border-b border-border dark:border-border-dark bg-surface2 dark:bg-surface2-dark">
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              width="400"
              height="225"
              class="w-full h-full object-cover"
            />
            {post.data.rating !== undefined && (
              <div class="absolute bottom-12 right-12 z-10 bg-surface dark:bg-surface-dark p-2 rounded-pill border border-border dark:border-border-dark shadow-card">
                <VerdictGauge score={post.data.rating} size={48} />
              </div>
            )}
          </div>
          <div class="p-16 flex-1 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-8 mb-12">
                <span class="badge">
                  {post.data.category}
                </span>
                {post.data.isPillar && (
                  <span class="badge">
                    Pillar Guide
                  </span>
                )}
              </div>
              <h3 class="text-h3 font-display font-semibold leading-snug text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
                {post.data.title}
              </h3>
              <p class="text-meta font-sans text-ink2 dark:text-ink2-dark line-clamp-2 leading-relaxed mt-12">
                {post.data.description}
              </p>
            </div>
            <div class="text-meta font-mono font-semibold text-muted dark:text-muted-dark mt-16">
              {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
