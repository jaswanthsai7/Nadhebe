/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://images.unsplash.com https://img.youtube.com https://www.youtube.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com https://img.youtube.com https://i.ytimg.com https://nadhebe.pages.dev; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self' http://localhost:8787 https://api.nadhebe.com;
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/.well-known/oauth-protected-resource
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/openid-configuration
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/oauth-authorization-server
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *
