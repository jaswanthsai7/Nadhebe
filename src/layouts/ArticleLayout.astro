---
import { getEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import PreviousNext from '@/components/PreviousNext.astro';
import FAQSection from '@/components/FAQSection.astro';
import SourceList from '@/components/SourceList.astro';
import YouTubeEmbed from '../components/content/YouTubeEmbed.astro';
import ArticleSchema from '../components/seo/ArticleSchema.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import VideoSchema from '../components/seo/VideoSchema.astro';
import ReviewSchema from '../components/seo/ReviewSchema.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import ScrollToTop from '@/components/ScrollToTop.astro';
import MobileToc from '@/components/MobileToc.astro';
import Newsletter from '@/components/Newsletter.astro';
import AuthorCard from '@/components/AuthorCard.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import VerdictGauge from '@/components/VerdictGauge.astro';

import { getReadingTime } from '../utils/readingTime';
import { getRelatedArticles } from '../utils/relatedArticles';
import { getBreadcrumbs } from '../utils/breadcrumbs';
import { getAllArticles, getArticleUrl } from '../utils/content';

const { post } = Astro.props;
const { Content, headings } = await post.render();

const authorEntry = await getEntry(post.data.author);
const author = authorEntry?.data;

const slug = getArticleUrl(post);
const readingTime = getReadingTime(post.body);
const pageUrl = new URL(slug, Astro.site || Astro.url.origin).toString();

const allArticles = await getAllArticles();

const currentTopic = post.data.topic;
let parentPillarArticle = null;
let supportingArticles: typeof allArticles = [];

if (currentTopic) {
  if (post.data.isPillar) {
    supportingArticles = allArticles.filter(
      a => a.data.topic?.toLowerCase() === currentTopic.toLowerCase() && !a.data.isPillar
    );
  } else if (post.data.parentPillar) {
    parentPillarArticle = allArticles.find(
      a => a.slug === post.data.parentPillar && a.data.isPillar
    );
  }
}

const relatedArticles = getRelatedArticles(post, allArticles, 3);

const siblingArticles = allArticles.filter(a => a.collection === post.collection);
const currentIndex = siblingArticles.findIndex(a => a.slug === post.slug);
const prevArticle = currentIndex < siblingArticles.length - 1 ? siblingArticles[currentIndex + 1] : null;
const nextArticle = currentIndex > 0 ? siblingArticles[currentIndex - 1] : null;

const prevProps = prevArticle ? { title: prevArticle.data.title, url: getArticleUrl(prevArticle) } : undefined;
const nextProps = nextArticle ? { title: nextArticle.data.title, url: getArticleUrl(nextArticle) } : undefined;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const references = post.data.sources?.map((s) => ({
  title: s.label,
  url: s.url,
})) || [];

let collectionLabel = '';
let collectionHref = '';
switch (post.collection) {
  case 'news':         collectionLabel = 'News';        collectionHref = '/news';        break;
  case 'tutorials':    collectionLabel = 'Tutorials';   collectionHref = '/tutorials';   break;
  case 'youtube-articles': collectionLabel = 'Videos';  collectionHref = '/youtube';     break;
  case 'tool-reviews': collectionLabel = 'Reviews';     collectionHref = '/reviews';     break;
  case 'prompts':      collectionLabel = 'Prompts';     collectionHref = '/prompts';     break;
  case 'comparisons':  collectionLabel = 'Comparisons'; collectionHref = '/comparisons'; break;
  case 'best-practices': collectionLabel = 'Best Practices'; collectionHref = '/best-practices'; break;
  case 'use-cases':    collectionLabel = 'Use Cases';     collectionHref = '/use-cases';    break;
  case 'tools':        collectionLabel = 'Tools';         collectionHref = '/tools';        break;
  case 'guides':       collectionLabel = 'Guides';        collectionHref = '/guides';       break;
  case 'frameworks':   collectionLabel = 'Frameworks';    collectionHref = '/frameworks';   break;
  case 'case-studies': collectionLabel = 'Case Studies';  collectionHref = '/case-studies'; break;
  default:             collectionLabel = 'Articles';    collectionHref = '/';
}

const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: collectionLabel, href: collectionHref },
  { name: post.data.title, href: slug },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  heroImage={post.data.heroImage}
  canonicalUrl={post.data.canonicalUrl}
>
  <ArticleSchema
    title={post.data.title}
    description={post.data.description}
    pubDate={post.data.pubDate}
    updatedDate={post.data.updatedDate}
    authorName={author?.name || 'Anonymous'}
    authorBio={author?.bio}
    authorAvatar={author?.avatar}
    heroImage={post.data.heroImage}
    canonicalUrl={pageUrl}
  />
  {post.data.faq && <FAQSchema faq={post.data.faq} />}
  {(post.data.youtubeVideoId || post.data.videoId) && (
    <VideoSchema
      title={post.data.title}
      description={post.data.description}
      videoId={post.data.youtubeVideoId || post.data.videoId}
      videoDuration={post.data.videoDuration || 'PT10M00S'}
      videoUploadDate={post.data.videoUploadDate || post.data.pubDate}
    />
  )}

  {post.collection === 'tool-reviews' && post.data.rating !== undefined && (
    <ReviewSchema
      productName={post.data.topic || post.data.title}
      description={post.data.description}
      heroImage={post.data.heroImage}
      ratingValue={post.data.rating}
      authorName={author?.name || 'Staff Writer'}
      price={post.data.pricing}
      canonicalUrl={pageUrl}
    />
  )}

  <ReadingProgress />
  <ScrollToTop />

  <div class="mx-auto mt-32 sm:mt-64 flex max-w-screen-xl items-start gap-48 px-16 sm:px-24" data-reveal>

    <!-- Balance spacer -->
    <div class="hidden xl:block w-sidebar shrink-0"></div>

    <!-- Center content -->
    <div class="flex-1 min-w-0">
      <div class="mx-auto max-w-3xl">

        <!-- Breadcrumb -->
        <Breadcrumb items={breadcrumbItems} />

        <!-- Hero header (glass panel for readability over nature background) -->
        <header class="mt-24 mb-48 rounded-16 p-24 sm:p-32 glass-panel border border-border dark:border-border-dark">
          <span class="badge mb-16 inline-block">{post.data.category}</span>

          <div class="flex flex-col sm:flex-row items-start gap-16 sm:gap-20">
            {post.collection === 'tool-reviews' && post.data.rating !== undefined && (
              <div class="shrink-0 mt-4">
                <VerdictGauge score={post.data.rating} size={72} />
              </div>
            )}
            <div>
              <h1 class="font-display text-h1 leading-tight font-bold text-ink dark:text-ink-dark sm:text-display">
                {post.data.title}
              </h1>
              <p class="mt-16 text-body-large leading-relaxed text-ink2 dark:text-ink2-dark">
                {post.data.description}
              </p>
            </div>
          </div>

          <!-- Author meta -->
          <div class="mt-32 pt-20 border-t border-border dark:border-border-dark flex flex-wrap items-center gap-x-12 gap-y-8 text-caption text-muted dark:text-muted-dark font-sans">
            <div class="flex items-center gap-8 font-medium text-ink2 dark:text-ink2-dark">
              {author?.avatar && (
                <img src={author.avatar} alt={author?.name} width="28" height="28"
                  class="h-24 w-24 rounded-pill object-cover ring-1 ring-border dark:ring-border-dark" />
              )}
              <span>{author?.name || 'Anonymous'}</span>
            </div>
            <span class="text-border dark:text-border-dark">·</span>
            <time datetime={post.data.pubDate.toISOString()} class="font-mono text-meta">{fmt(post.data.pubDate)}</time>
            <span class="text-border dark:text-border-dark">·</span>
            <span class="font-mono text-meta">{readingTime}</span>
          </div>
        </header>

        <!-- Hero image: only show when there is no YouTube embed (video already shows the thumbnail) -->
        {post.data.heroImage && post.collection !== 'tool-reviews' && !post.data.youtubeVideoId && !post.data.videoId && (
          <div class="mb-48 overflow-hidden rounded-16 border border-border dark:border-border-dark">
            <img
              src={post.data.heroImage}
              alt={post.data.heroAlt || post.data.title}
              width="800"
              height="450"
              class="w-full object-cover"
              style="max-height:360px; object-position:center top;"
              fetchpriority="high"
            />
          </div>
        )}

        <!-- Pillar cluster alert -->
        {parentPillarArticle && (
          <div class="mb-32 flex flex-col sm:flex-row sm:items-center justify-between gap-16 rounded-12 border border-accent/15 bg-accent/5 p-20">
            <div class="flex items-center gap-12">
              <div class="flex h-32 w-32 items-center justify-center rounded-8 bg-accent/10 text-accent dark:text-accent-dark">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
                  <path d="M12 2 2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-sans font-semibold text-accent dark:text-accent-dark uppercase tracking-wider">Topic Cluster</p>
                <p class="text-caption font-sans font-medium text-ink dark:text-ink-dark mt-2">
                  Part of: <strong>{currentTopic}</strong>
                </p>
              </div>
            </div>
            <a href={getArticleUrl(parentPillarArticle)} class="btn-primary py-8 px-16 text-caption shrink-0">
              Read pillar guide
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        )}

        <MobileToc headings={headings} />

        <!-- YouTube embed -->
        {(post.data.youtubeVideoId || post.data.videoId) && (
          <div class="mb-32">
            <YouTubeEmbed videoId={post.data.youtubeVideoId || post.data.videoId} title={post.data.title} />
          </div>
        )}

        <!-- Review verdict -->
        {post.collection === 'tool-reviews' && post.data.rating !== undefined && (
          <div class="mb-48 rounded-16 border border-border bg-surface p-24 dark:border-border-dark dark:bg-surface-dark">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-16 border-b border-border dark:border-border-dark pb-20 mb-20">
              <div class="flex items-center gap-16">
                <VerdictGauge score={post.data.rating} size={56} />
                <div>
                  <p class="text-xs font-sans font-semibold text-muted dark:text-muted-dark uppercase tracking-wider">Overall verdict</p>
                  <p class="text-caption font-sans font-semibold text-ink2 dark:text-ink2-dark mt-4">{post.data.rating >= 9.0 ? 'Recommended' : 'Average'}</p>
                </div>
              </div>
              <div>
                <p class="text-xs font-sans font-semibold text-muted dark:text-muted-dark uppercase tracking-wider">Pricing</p>
                <p class="text-caption font-sans font-semibold text-ink2 dark:text-ink2-dark mt-4 font-mono">{post.data.pricing || 'N/A'}</p>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-16">
              <div class="bg-success/5 border border-success/15 rounded-12 p-16">
                <p class="text-xs font-sans font-semibold text-success dark:text-success-dark uppercase tracking-wider mb-8">Pros</p>
                <ul class="space-y-6 text-caption font-sans text-ink2 dark:text-ink2-dark list-none pl-0">
                  {post.data.pros?.map(pro => (
                    <li class="flex items-start gap-8">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16 text-success dark:text-success-dark shrink-0 mt-1"><path d="M20 6 9 17l-5-5"/></svg>
                      {pro}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-danger/5 border border-danger/15 rounded-12 p-16">
                <p class="text-xs font-sans font-semibold text-danger dark:text-danger-dark uppercase tracking-wider mb-8">Cons</p>
                <ul class="space-y-6 text-caption font-sans text-ink2 dark:text-ink2-dark list-none pl-0">
                  {post.data.cons?.map(con => (
                    <li class="flex items-start gap-8">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16 text-danger dark:text-danger-dark shrink-0 mt-1"><path d="M18 6 6 18M6 6l12 12"/></svg>
                      {con}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        )}

        <!-- Comparison badge -->
        {post.collection === 'comparisons' && post.data.itemsCompared && (
          <div class="mb-32 flex items-center justify-between gap-16 rounded-12 border border-border bg-surface p-20 dark:border-border-dark dark:bg-surface-dark">
            <div>
              <p class="text-xs font-sans font-semibold text-muted dark:text-muted-dark uppercase tracking-wider mb-8">Comparing</p>
              <div class="flex flex-wrap gap-8">
                {post.data.itemsCompared.map(item => <span class="badge">{item}</span>)}
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-24 w-24 shrink-0 text-muted dark:text-muted-dark">
              <path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5" />
            </svg>
          </div>
        )}

        <!-- Article body -->
        <div class="glass-panel rounded-16 p-24 sm:p-32 border border-border dark:border-border-dark mb-32">
          <article class="prose-article" data-article-body>
            <Content />
          </article>
        </div>

        <!-- Supporting articles -->
        {post.data.isPillar && supportingArticles.length > 0 && (
          <div class="mt-64 border-t border-border dark:border-border-dark pt-32">
            <h2 class="section-title mb-8">Supporting guides</h2>
            <p class="text-caption font-sans text-ink2 dark:text-ink2-dark mb-24">Deeper dives into specific aspects:</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-16">
              {supportingArticles.map(art => (
                <a href={getArticleUrl(art)} class="card p-20 block group">
                  <span class="badge mb-8">{art.collection.replace('-articles', '')}</span>
                  <h3 class="font-display text-h4 font-semibold text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors duration-150 mt-8 mb-4">{art.data.title}</h3>
                  <p class="text-xs font-sans text-muted dark:text-muted-dark line-clamp-2">{art.data.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <FAQSection items={post.data.faq || []} />
        <SourceList references={references} />

        <!-- Author + share -->
        <div class="not-prose mt-48 sm:mt-64 flex flex-col gap-24 border-t border-border pt-24 sm:pt-32 dark:border-border-dark">
          {author && (
            <div class="flex-grow">
              <AuthorCard
                name={author.name}
                role={author.role}
                avatar={author.avatar}
                bio={author.bio}
                twitter={author.twitter}
                reviewedBy={post.data.reviewedBy}
                updatedDate={post.data.updatedDate ? fmt(post.data.updatedDate) : undefined}
              />
            </div>
          )}
          <div class="flex items-center justify-end">
            <ShareButtons url={pageUrl} title={post.data.title} />
          </div>
        </div>
      </div>
    </div>

    <!-- Right sidebar -->
    <aside class="hidden xl:block w-sidebar shrink-0 sticky top-80 self-start">
      <TableOfContents headings={headings} />
    </aside>

  </div>

  <!-- Bottom section -->
  <div class="mx-auto max-w-content px-16 sm:px-24 pb-64 sm:pb-96 mt-48 sm:mt-64 border-t border-border dark:border-border-dark pt-32 sm:pt-48">
    <RelatedPosts posts={relatedArticles} />
    <div class="mt-32">
      <PreviousNext prev={prevProps} next={nextProps} />
    </div>
    <div class="mt-48">
      <Newsletter />
    </div>
  </div>

  <script>
    function addCopyButtons() {
      const preBlocks = document.querySelectorAll('.prose-article pre');

      preBlocks.forEach((pre) => {
        if (pre.querySelector('.copy-btn') || pre.parentElement?.classList.contains('pre-wrapper')) return;

        const wrapper = document.createElement('div');
        wrapper.className = 'relative group pre-wrapper w-full';

        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        const button = document.createElement('button');
        button.className = 'copy-btn absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-opacity duration-200 px-8 py-4 text-xs font-mono rounded-6 border border-border-dark bg-surface2-dark text-muted-dark hover:text-ink-dark';
        button.type = 'button';
        button.ariaLabel = 'Copy code to clipboard';
        button.innerHTML = 'Copy';

        button.addEventListener('click', async () => {
          const code = (pre as HTMLElement).querySelector('code')?.innerText || (pre as HTMLElement).innerText;
          try {
            await navigator.clipboard.writeText(code);
            button.innerHTML = 'Copied';
            setTimeout(() => {
              button.innerHTML = 'Copy';
            }, 2000);
          } catch (err) {
            console.error('Failed to copy text: ', err);
            button.innerHTML = 'Failed';
          }
        });

        wrapper.appendChild(button);
      });
    }

    addCopyButtons();
    document.addEventListener('astro:page-load', addCopyButtons);
  </script>
</BaseLayout>
