z---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SearchDialog from '@/components/search/SearchDialog.astro';
import '@/styles/global.css';
import { buildSeo } from '@/utils/seo';
import { SITE } from '@/config';
import type { SeoMeta } from '@/utils/seo';

interface Props {
  seo?: SeoMeta;
  title?: string;
  description?: string;
  heroImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>[];
}

const { seo: propSeo, title, description, heroImage, canonicalUrl, jsonLd = [] } = Astro.props;

const seo = propSeo || buildSeo({
  title: title || SITE.name,
  description: description || SITE.description,
  slug: Astro.url.pathname,
  siteUrl: SITE.url,
  siteName: SITE.name,
  image: heroImage,
});

if (canonicalUrl) {
  seo.canonical = canonicalUrl;
}
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <!-- Prevent flash: apply stored theme or default dark before paint -->
    <script is:inline>
      (function() {
        const t = localStorage.getItem('theme');
        if (t === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={seo.robots} />
    {seo.keywords && <meta name="keywords" content={seo.keywords} />}
    {seo.author && <meta name="author" content={seo.author} />}
    <link rel="canonical" href={seo.canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:url" content={seo.ogUrl} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:image:alt" content={seo.ogImageAlt} />
    <meta property="og:locale" content={seo.locale} />
    {seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
    {seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={seo.twitterTitle} />
    <meta name="twitter:description" content={seo.twitterDescription} />
    <meta name="twitter:image" content={seo.twitterImage} />

    <!-- Structured data -->
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}



    <!-- Frosted Nature Background Styles -->
    <style>
      #nature-bg {
        position: fixed;
        inset: 0;
        z-index: -20;
        width: 100vw;
        height: 100vh;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        transition: opacity 0.8s ease;
        opacity: 0;
      }
      #nature-overlay {
        position: fixed;
        inset: 0;
        z-index: -10;
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.0) 0%,
          rgba(255, 255, 255, 0.08) 100%
        );
        pointer-events: none;
      }
      .dark #nature-overlay {
        background: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.0) 0%,
          rgba(0, 0, 0, 0.18) 100%
        );
      }
    </style>

    <!-- WebMCP Agent Tools Registration -->
    <script is:inline>
      if (navigator.modelContext && typeof navigator.modelContext.provideContext === 'function') {
        navigator.modelContext.provideContext({
          tools: [
            {
              name: "search_articles",
              description: "Search all articles, system prompts, comparisons, and tool reviews on the platform.",
              inputSchema: {
                type: "object",
                properties: {
                  query: { type: "string", description: "Search query string" }
                },
                required: ["query"]
              },
              execute: async ({ query }) => {
                window.location.href = `/search?q=${encodeURIComponent(query)}`;
                return { success: true, message: `Navigated to search for: ${query}` };
              }
            }
          ]
        });
      }
    </script>
  </head>
  <body class="flex min-h-screen flex-col text-ink dark:text-ink-dark" style="background: transparent;">
    <!-- Full-screen Dynamic Nature Background -->
    <div id="nature-bg" role="presentation" aria-hidden="true"></div>
    <div id="nature-overlay" aria-hidden="true"></div>

    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class="flex-grow">
      <slot />
    </main>
    <Footer />
    <SearchDialog />

    <!-- Curated random nature image loader (Only cycles on refresh or tab switch) -->
    <script is:inline>
      (function () {
        const photos = [
          'photo-1507525428034-b723cf961d3e', // tropical beach
          'photo-1441974231531-c6227db76b6e', // forest
          'photo-1505118380757-91f5f5632de0', // beach shore
          'photo-1534067783941-51c9c23ecefd', // green jungle
          'photo-1470071459604-3b5ec3a7fe05', // misty forest lake
          'photo-1500382017468-9049fed747ef', // sunlit green landscape
          'photo-1439066615861-d1af74d74000', // palm beach
          'photo-1518495973542-4542c06a5843', // sunlit trees
          'photo-1448375240586-882707db888b', // green redwood forest
          'photo-1506973035872-a4ec16b8e8d9', // beach shore bay
          'photo-1544551763-46a013bb70d5', // tropical turquoise reef
          'photo-1476514525535-07fb3b4ae5f1', // forest lake
          'photo-1502082553048-f009c37129b9', // deep green foliage
          'photo-1519046904884-53103b34b206', // clear water beach
          'photo-1470240731273-7821a6eeb6bd'  // lush green lake forest
        ];

        // Fisher-Yates shuffle
        function shuffle(arr) {
          const a = arr.slice();
          for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
          }
          return a;
        }

        function applyBg(cycle) {
          let queue;
          let idx;
          try {
            const stored = sessionStorage.getItem('nb_bg_queue');
            const storedIdx = parseInt(sessionStorage.getItem('nb_bg_idx') || '-1', 10);
            queue = stored ? JSON.parse(stored) : null;
            idx = storedIdx;
          } catch (e) {
            queue = null;
            idx = -1;
          }

          let currentBgId = sessionStorage.getItem('nb_current_bg');

          // Cycle if forced, or if we don't have a background set yet
          if (cycle || !currentBgId) {
            if (!queue || idx >= queue.length - 1) {
              queue = shuffle(photos);
              idx = 0;
            } else {
              idx = idx + 1;
            }
            currentBgId = queue[idx];

            try {
              sessionStorage.setItem('nb_bg_queue', JSON.stringify(queue));
              sessionStorage.setItem('nb_bg_idx', String(idx));
              sessionStorage.setItem('nb_current_bg', currentBgId);
            } catch (e) {}
          }

          const src = 'https://images.unsplash.com/' + currentBgId + '?auto=format&fit=crop&w=3840&q=100';
          const bg = document.getElementById('nature-bg');
          if (bg) {
            const img = new Image();
            img.onload = function () {
              bg.style.backgroundImage = "url('" + src + "')";
              bg.style.opacity = '1';
            };
            img.src = src;
          }
        }

        // Detect if this page load is a reload/refresh
        const isReload = (performance.getEntriesByType("navigation")[0]?.type === "reload") ||
                         (window.performance && window.performance.navigation && window.performance.navigation.type === 1);

        // Apply bg: cycle if refresh, otherwise reuse previous background
        applyBg(isReload);

        // Cycle bg on browser tab visibility change (moving to another tab and back)
        document.addEventListener('visibilitychange', function () {
          if (document.visibilityState === 'visible') {
            applyBg(true);
          }
        });
      })();
    </script>
  </body>
</html>
