---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  toolName: string;
  category: string;
  categoryUrl: string;
  faqs?: { question: string; answer: string }[];
}

const { title, description, toolName, category, categoryUrl, faqs } = Astro.props;

const pageUrl = Astro.url.href;

// Dynamic JSON-LD schemas
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": toolName,
    "operatingSystem": "All",
    "applicationCategory": "DeveloperApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
];

if (faqs && faqs.length > 0) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.answer
      }
    }))
  });
}
---

<BaseLayout title={`${title} - Nadhebe`} description={description} canonicalUrl={pageUrl} jsonLd={jsonLd}>
  <div class="mx-auto max-w-6xl px-24 py-48 sm:py-64">
    <!-- Breadcrumbs -->
    <nav class="mb-24 flex items-center gap-8 text-meta text-muted dark:text-muted-dark" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent dark:hover:text-accent-dark transition-colors">Home</a>
      <span class="text-border dark:text-border-dark">/</span>
      <a href="/tools" class="hover:text-accent dark:hover:text-accent-dark transition-colors">Tools</a>
      <span class="text-border dark:text-border-dark">/</span>
      <a href={categoryUrl} class="hover:text-accent dark:hover:text-accent-dark transition-colors">{category}</a>
      <span class="text-border dark:text-border-dark">/</span>
      <span class="text-ink dark:text-ink-dark font-medium">{toolName}</span>
    </nav>

    <!-- Header section -->
    <header class="border-b border-border dark:border-border-dark pb-24 mb-32">
      <h1 class="font-display text-h1 sm:text-display font-bold text-ink dark:text-ink-dark leading-tight">{toolName}</h1>
      <p class="mt-12 text-body-large text-ink2 dark:text-ink2-dark max-w-3xl leading-relaxed">{description}</p>
    </header>

    <!-- Interactive Tool Interface (Side-by-Side Split View) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-24 mb-48 items-stretch">
      <!-- Inputs (Left Column) -->
      <div class="lg:col-span-6 flex flex-col justify-between rounded-16 border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-24 shadow-subtle relative">
        <div>
          <h2 class="text-h3 font-display font-bold text-ink dark:text-ink-dark mb-16 border-b border-border dark:border-border-dark pb-8">Configure Options</h2>
          <slot name="input" />
        </div>
      </div>
      
      <!-- Outputs (Right Column) -->
      <div class="lg:col-span-6 flex flex-col justify-between rounded-16 border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-24 shadow-subtle relative min-h-[350px]">
        <div>
          <h2 class="text-h3 font-display font-bold text-ink dark:text-ink-dark mb-16 border-b border-border dark:border-border-dark pb-8">Result Output</h2>
          <slot name="output" />
        </div>
      </div>
    </div>

    <!-- Security & Privacy Notice -->
    <div class="mb-48 p-16 rounded-12 border border-accent/15 bg-accent/5 flex items-start gap-12">
      <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-pill bg-accent/10 text-accent dark:text-accent-dark">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-14 w-14">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </div>
      <div>
        <p class="text-caption font-sans font-semibold text-accent dark:text-accent-dark uppercase tracking-wider">Client-Side Privacy Sandbox</p>
        <p class="text-caption text-ink2 dark:text-ink2-dark mt-2 leading-relaxed">
          This is a free developer utility. All operations run directly in your browser's sandboxed memory. No files, passwords, or texts are sent to external servers or logged.
        </p>
      </div>
    </div>

    <!-- Educational & Context Sections -->
    <article class="prose dark:prose-invert max-w-none mt-48 border-t border-border dark:border-border-dark pt-48">
      <slot />

      <!-- FAQ Accordions -->
      {faqs && faqs.length > 0 && (
        <div class="mt-48">
          <h2 class="text-h2 font-display font-bold text-ink dark:text-ink-dark mb-24">Frequently Asked Questions</h2>
          <div class="space-y-16">
            {faqs.map((f, index) => (
              <details class="group rounded-12 border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-16 [&_summary::-webkit-details-marker]:hidden" open={index === 0}>
                <summary class="flex cursor-pointer items-center justify-between gap-16 font-sans font-semibold text-ink dark:text-ink-dark hover:text-accent dark:hover:text-accent-dark transition-colors duration-150">
                  <span>{f.question}</span>
                  <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-12 text-body text-ink2 dark:text-ink2-dark leading-relaxed">
                  <p>{f.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      )}
    </article>
  </div>
</BaseLayout>
