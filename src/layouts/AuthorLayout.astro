---
import BaseLayout from './BaseLayout.astro';
import { getArticleUrl } from '../utils/content';
import VerdictGauge from '@/components/VerdictGauge.astro';

interface Props {
  author: {
    name: string;
    bio: string;
    avatar: string;
    twitter?: string;
    github?: string;
  };
  posts: any[];
}

const { author, posts } = Astro.props;

// Filter posts written by author into Pillar and Supporting
const pillarPosts = posts.filter(p => p.data.isPillar === true);
const supportingPosts = posts.filter(p => !p.data.isPillar);
---

<BaseLayout
  title={`Author Profile: ${author.name}`}
  description={`${author.name} is a contributor writing about artificial intelligence, coding agents, and prompts.`}
>
  <div class="mx-auto max-w-5xl px-24 py-64 sm:py-96" data-reveal>
    <!-- Author Profile Card -->
    <div class="card flex flex-col md:flex-row items-center md:items-start gap-24 p-24 mb-48">
      <img
        src={author.avatar}
        alt={author.name}
        width="96"
        height="96"
        class="h-96 w-96 rounded-control object-cover border border-border dark:border-border-dark"
      />
      <div class="flex-1 text-center md:text-left">
        <p class="text-meta font-sans font-semibold text-accent dark:text-accent-dark uppercase tracking-wider mb-8">Author Profile</p>
        <h1 class="font-display text-h1 font-bold text-ink dark:text-ink-dark">{author.name}</h1>
        <p class="text-ink2 dark:text-ink2-dark text-body mt-16 max-w-3xl leading-relaxed">{author.bio}</p>
        
        <!-- Socials -->
        <div class="flex items-center justify-center md:justify-start gap-16 mt-24">
          {author.twitter && (
            <a
              href={author.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-8 text-meta font-sans text-muted hover:text-ink dark:hover:text-ink-dark transition-colors"
            >
              <svg class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              <span>Twitter</span>
            </a>
          )}
          {author.github && (
            <a
              href={author.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-8 text-meta font-sans text-muted hover:text-ink dark:hover:text-ink-dark transition-colors"
            >
              <svg class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <span>GitHub</span>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Articles Section -->
    <div class="space-y-96">
      <!-- Pillar Articles -->
      {pillarPosts.length > 0 && (
        <div>
          <h2 class="font-display text-h2 font-semibold text-ink dark:text-ink-dark mb-24 flex items-center gap-8">
            Pillar Guides
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-24">
            {pillarPosts.map(post => (
              <a
                href={getArticleUrl(post)}
                class="card group flex flex-col overflow-hidden p-0"
              >
                <div class="aspect-video w-full overflow-hidden relative border-b border-border dark:border-border-dark">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width="480"
                    height="270"
                    class="w-full h-full object-cover"
                  />
                  {post.data.rating !== undefined && (
                    <div class="absolute bottom-12 right-12 z-10 bg-surface dark:bg-surface-dark p-2 rounded-pill border border-border dark:border-border-dark shadow-card">
                      <VerdictGauge score={post.data.rating} size={48} />
                    </div>
                  )}
                </div>
                <div class="p-24">
                  <span class="badge mb-12">
                    Pillar Guide
                  </span>
                  <h3 class="text-h3 font-display font-semibold text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-body text-ink2 dark:text-ink2-dark line-clamp-2 leading-relaxed mt-12">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Supporting Articles -->
      {supportingPosts.length > 0 && (
        <div>
          <h2 class="font-display text-h2 font-semibold text-ink dark:text-ink-dark mb-24 flex items-center gap-8">
            📝 Other guides & tutorials
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-24">
            {supportingPosts.map(post => (
              <a
                href={getArticleUrl(post)}
                class="card group flex flex-col overflow-hidden p-0"
              >
                <div class="aspect-video w-full overflow-hidden relative border-b border-border dark:border-border-dark">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width="320"
                    height="180"
                    class="w-full h-full object-cover"
                  />
                  {post.data.rating !== undefined && (
                    <div class="absolute bottom-12 right-12 z-10 bg-surface dark:bg-surface-dark p-2 rounded-pill border border-border dark:border-border-dark shadow-card">
                      <VerdictGauge score={post.data.rating} size={48} />
                    </div>
                  )}
                </div>
                <div class="p-16 flex-1 flex flex-col justify-between">
                  <div>
                    <span class="badge mb-12">
                      {post.data.category}
                    </span>
                    <h3 class="text-h3 font-display font-semibold leading-snug text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-meta font-sans text-ink2 dark:text-ink2-dark line-clamp-2 leading-relaxed mt-8">
                      {post.data.description}
                    </p>
                  </div>
                  <div class="text-meta text-muted dark:text-muted-dark mt-16 flex items-center justify-between">
                    <span class="font-mono font-semibold">
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                      })}
                    </span>
                    {post.data.difficulty && <span class="capitalize font-sans font-semibold">{post.data.difficulty}</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {posts.length === 0 && (
        <div class="text-center py-64 border border-dashed border-border dark:border-border-dark rounded-card">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-32 w-32 mx-auto text-muted dark:text-muted-dark"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><path d="M14 2v6h6" /></svg>
          <p class="text-muted dark:text-muted-dark mt-16">No articles written by this author yet.</p>
          <p class="text-meta font-sans text-muted dark:text-muted-dark mt-8">
            <a href="/" class="text-accent dark:text-accent-dark hover:underline">Return to the homepage</a> to read our latest guides.
          </p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
