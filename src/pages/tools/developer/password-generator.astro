---
import ToolLayout from '@/layouts/ToolLayout.astro';
import { toolsData } from '@/data/toolsList';

const tool = toolsData.find(c => c.slug === 'developer')?.tools.find(t => t.slug === 'password-generator')!;
---

<ToolLayout
  title={tool.name}
  description={tool.description}
  toolName={tool.name}
  category="Developer Tools"
  categoryUrl="/tools/developer"
  faqs={tool.faqs}
>
  <!-- Inputs Left Column -->
  <div slot="input" class="space-y-16">
    <div>
      <div class="flex justify-between items-center mb-8">
        <label for="pwd-length" class="block text-meta font-sans font-semibold text-ink dark:text-ink-dark">Length: <span id="length-val" class="text-accent">16</span> chars</label>
      </div>
      <input
        type="range"
        id="pwd-length"
        min="6"
        max="128"
        value="16"
        class="w-full h-6 bg-surface2 dark:bg-surface2-dark rounded-pill appearance-none cursor-pointer accent-accent"
      />
    </div>
    
    <div class="flex flex-col gap-12 pt-16 border-t border-border dark:border-border-dark">
      <label class="flex items-center gap-8 cursor-pointer select-none">
        <input type="checkbox" id="pwd-upper" checked class="rounded border-border text-accent focus:ring-accent w-16 h-16" />
        <span class="text-caption text-ink dark:text-ink-dark">Uppercase Letters (A-Z)</span>
      </label>
      <label class="flex items-center gap-8 cursor-pointer select-none">
        <input type="checkbox" id="pwd-lower" checked class="rounded border-border text-accent focus:ring-accent w-16 h-16" />
        <span class="text-caption text-ink dark:text-ink-dark">Lowercase Letters (a-z)</span>
      </label>
      <label class="flex items-center gap-8 cursor-pointer select-none">
        <input type="checkbox" id="pwd-numbers" checked class="rounded border-border text-accent focus:ring-accent w-16 h-16" />
        <span class="text-caption text-ink dark:text-ink-dark">Numbers (0-9)</span>
      </label>
      <label class="flex items-center gap-8 cursor-pointer select-none">
        <input type="checkbox" id="pwd-symbols" checked class="rounded border-border text-accent focus:ring-accent w-16 h-16" />
        <span class="text-caption text-ink dark:text-ink-dark">Special Characters (!@#$%^&*...)</span>
      </label>
    </div>
    
    <button
      id="generate-pwd-btn"
      class="w-full mt-16 btn bg-accent hover:bg-accent/90 text-white font-sans font-semibold py-12 rounded-control transition-all"
    >
      Generate Password
    </button>
  </div>

  <!-- Outputs Right Column -->
  <div slot="output" class="flex flex-col justify-between h-full min-h-[300px]">
    <div class="space-y-16">
      <div class="relative">
        <input
          type="text"
          id="pwd-output"
          readonly
          class="w-full rounded-control border border-border dark:border-border-dark bg-code dark:bg-code-dark font-mono text-body p-16 pr-48 text-ink dark:text-ink-dark focus:outline-none"
          placeholder="Secure password will appear here..."
        />
        <!-- Regenerate button -->
        <button id="regen-icon-btn" class="absolute right-12 top-1/2 -translate-y-1/2 text-muted hover:text-ink dark:hover:text-ink-dark transition-colors" title="Regenerate">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-20 w-20">
            <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67" />
          </svg>
        </button>
      </div>

      <!-- Strength Gauge -->
      <div class="rounded-12 border border-border dark:border-border-dark p-12 bg-surface2 dark:bg-surface2-dark">
        <div class="flex items-center justify-between text-caption font-semibold mb-6">
          <span class="text-ink2 dark:text-ink2-dark">Strength Security Rank:</span>
          <span id="strength-label" class="text-danger">Weak</span>
        </div>
        <div class="w-full h-8 bg-border dark:bg-border-dark rounded-pill overflow-hidden">
          <div id="strength-bar" class="w-[20%] h-full bg-danger transition-all duration-300"></div>
        </div>
        <p class="text-xs text-muted mt-8" id="entropy-label">Entropy: 0 bits</p>
      </div>
    </div>

    <div class="mt-16">
      <button
        id="copy-pwd-btn"
        class="w-full btn border border-border dark:border-border-dark text-ink dark:text-ink-dark hover:bg-hover dark:hover:bg-hover-dark py-12 rounded-control font-sans font-semibold flex items-center justify-center gap-8 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
        </svg>
        <span id="copy-pwd-text">Copy Password</span>
      </button>
    </div>
  </div>

  <!-- Educational Section -->
  <h2 class="text-h2 font-display font-bold text-ink dark:text-ink-dark mb-16">Understanding Password Entropy Math</h2>
  <p class="text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-16">
    Password strength is not just about complexity; it is primarily driven by **entropy**, which measures the unpredictability of a string in bits. The formula for password entropy is:
  </p>
  <div class="bg-code dark:bg-code-dark border border-border dark:border-border-dark rounded-12 p-16 font-mono text-caption text-ink dark:text-ink-dark max-w-sm mb-24">
    E = L × log₂ ( R )
  </div>
  <p class="text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-24">
    Where <code>L</code> is the password length, and <code>R</code> is the size of the character pool selected (Lowercase=26, Uppercase=26, Numbers=10, Symbols=33; total pool size = 95). Higher entropy values mean exponentially more guesses are required for an attacker running brute-force dictionaries to crack it.
  </p>

  <h2 class="text-h2 font-display font-bold text-ink dark:text-ink-dark mb-16">Recommended Entropy Ranks</h2>
  <table class="w-full text-left border-collapse border border-border dark:border-border-dark mb-32">
    <thead>
      <tr class="bg-surface2 dark:bg-surface2-dark text-caption font-semibold">
        <th class="p-12 border border-border dark:border-border-dark text-ink dark:text-ink-dark">Entropy Bits</th>
        <th class="p-12 border border-border dark:border-border-dark text-ink dark:text-ink-dark">Strength Rank</th>
        <th class="p-12 border border-border dark:border-border-dark text-ink dark:text-ink-dark">Brute Force Difficulty</th>
      </tr>
    </thead>
    <tbody class="text-caption text-ink2 dark:text-ink2-dark">
      <tr>
        <td class="p-12 border border-border dark:border-border-dark">&lt; 50 bits</td>
        <td class="p-12 border border-border dark:border-border-dark font-semibold text-danger">Weak</td>
        <td class="p-12 border border-border dark:border-border-dark">Very low. Vulnerable to fast dictionary attacks.</td>
      </tr>
      <tr>
        <td class="p-12 border border-border dark:border-border-dark">50 to 80 bits</td>
        <td class="p-12 border border-border dark:border-border-dark font-semibold text-rating-gold dark:text-rating-gold-dark">Medium</td>
        <td class="p-12 border border-border dark:border-border-dark">Moderate. Safe for generic user login screens.</td>
      </tr>
      <tr>
        <td class="p-12 border border-border dark:border-border-dark">&gt; 80 bits</td>
        <td class="p-12 border border-border dark:border-border-dark font-semibold text-success">Strong</td>
        <td class="p-12 border border-border dark:border-border-dark">Extremely high. Immune to standard brute force attacks.</td>
      </tr>
    </tbody>
  </table>

  <!-- Client-side Interactive Script -->
  <script>
    function setupPasswordGenerator() {
      const lengthInput = document.getElementById('pwd-length') as HTMLInputElement | null;
      const lengthVal = document.getElementById('length-val');
      const isUpper = document.getElementById('pwd-upper') as HTMLInputElement | null;
      const isLower = document.getElementById('pwd-lower') as HTMLInputElement | null;
      const isNum = document.getElementById('pwd-numbers') as HTMLInputElement | null;
      const isSym = document.getElementById('pwd-symbols') as HTMLInputElement | null;
      const generateBtn = document.getElementById('generate-pwd-btn');
      const regenBtn = document.getElementById('regen-icon-btn');
      const outputVal = document.getElementById('pwd-output') as HTMLInputElement | null;
      const strengthText = document.getElementById('strength-label');
      const strengthBar = document.getElementById('strength-bar');
      const entropyText = document.getElementById('entropy-label');
      const copyBtn = document.getElementById('copy-pwd-btn');
      const copyText = document.getElementById('copy-pwd-text');

      if (!generateBtn || !outputVal || !lengthInput) return;

      const upperChars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
      const lowerChars = 'abcdefghijklmnopqrstuvwxyz';
      const numberChars = '0123456789';
      const symbolChars = '!@#$%^&*()_+-=[]{}|;:,.<>?';

      function generatePassword() {
        let pool = '';
        let poolSize = 0;
        
        if (isUpper?.checked) { pool += upperChars; poolSize += 26; }
        if (isLower?.checked) { pool += lowerChars; poolSize += 26; }
        if (isNum?.checked) { pool += numberChars; poolSize += 10; }
        if (isSym?.checked) { pool += symbolChars; poolSize += 26; }

        if (!pool) {
          outputVal!.value = '';
          if (strengthText) strengthText.textContent = 'Select options';
          if (strengthBar) strengthBar.className = 'w-[0%] h-full bg-border';
          if (entropyText) entropyText.textContent = 'Entropy: 0 bits';
          return;
        }

        const len = parseInt(lengthInput?.value || '16');
        
        // Cryptographically strong random selection
        const randomValues = new Uint32Array(len);
        window.crypto.getRandomValues(randomValues);

        let password = '';
        for (let i = 0; i < len; i++) {
          password += pool[randomValues[i] % pool.length];
        }

        outputVal!.value = password;

        // Compute Entropy
        const entropy = Math.round(len * Math.log2(poolSize));
        if (entropyText) entropyText.textContent = `Entropy: ${entropy} bits`;

        // Update strength gauge
        if (strengthText && strengthBar) {
          if (entropy < 50) {
            strengthText.textContent = 'Weak';
            strengthText.className = 'text-danger';
            strengthBar.className = 'w-[25%] h-full bg-danger transition-all duration-300';
          } else if (entropy < 80) {
            strengthText.textContent = 'Medium';
            strengthText.className = 'text-rating-gold dark:text-rating-gold-dark';
            strengthBar.className = 'w-[60%] h-full bg-rating-gold dark:bg-rating-gold-dark transition-all duration-300';
          } else {
            strengthText.textContent = 'Strong';
            strengthText.className = 'text-success';
            strengthBar.className = 'w-[100%] h-full bg-success transition-all duration-300';
          }
        }
      }

      // Sync slider value
      lengthInput.addEventListener('input', () => {
        if (lengthVal) lengthVal.textContent = lengthInput.value;
        generatePassword();
      });

      // Bind buttons
      generateBtn.addEventListener('click', generatePassword);
      if (regenBtn) regenBtn.addEventListener('click', generatePassword);

      [isUpper, isLower, isNum, isSym].forEach(cb => {
        cb?.addEventListener('change', generatePassword);
      });

      // Initial gen
      generatePassword();

      // Copy callback
      if (copyBtn && copyText) {
        copyBtn.addEventListener('click', () => {
          const pass = outputVal.value;
          if (!pass) return;
          navigator.clipboard.writeText(pass).then(() => {
            copyText.textContent = 'Copied!';
            copyBtn.classList.add('bg-success/10', 'border-success/30', 'text-success');
            setTimeout(() => {
              copyText.textContent = 'Copy Password';
              copyBtn.classList.remove('bg-success/10', 'border-success/30', 'text-success');
            }, 2000);
          });
        });
      }
    }

    // Set up
    setupPasswordGenerator();
    document.addEventListener('astro:page-load', setupPasswordGenerator);
  </script>
</ToolLayout>
