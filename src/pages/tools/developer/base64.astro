---
import ToolLayout from '@/layouts/ToolLayout.astro';
import { toolsData } from '@/data/toolsList';

const tool = toolsData.find(c => c.slug === 'developer')?.tools.find(t => t.slug === 'base64')!;
---

<ToolLayout
  title={tool.name}
  description={tool.description}
  toolName={tool.name}
  category="Developer Tools"
  categoryUrl="/tools/developer"
  faqs={tool.faqs}
>
  <!-- Inputs Left Column -->
  <div slot="input" class="flex flex-col justify-between h-full min-h-[300px]">
    <div class="relative flex-grow">
      <textarea
        id="base64-input"
        class="w-full h-[280px] rounded-control border border-border dark:border-border-dark bg-surface2 dark:bg-surface2-dark font-mono text-meta p-12 text-ink dark:text-ink-dark focus:outline-none resize-none"
        placeholder="Enter plain text or Base64 string here..."
      ></textarea>
    </div>
    <div class="mt-16 flex gap-12">
      <button
        id="encode-btn"
        class="flex-1 btn bg-accent hover:bg-accent/90 text-white font-sans font-semibold py-12 rounded-control transition-all"
      >
        Encode (Text ➔ B64)
      </button>
      <button
        id="decode-btn"
        class="flex-1 btn border border-border dark:border-border-dark text-ink dark:text-ink-dark hover:bg-hover dark:hover:bg-hover-dark py-12 rounded-control font-sans font-semibold transition-colors"
      >
        Decode (B64 ➔ Text)
      </button>
    </div>
  </div>

  <!-- Outputs Right Column -->
  <div slot="output" class="flex flex-col justify-between h-full min-h-[300px]">
    <div class="space-y-12 flex-grow flex flex-col">
      <!-- Base64 Status Notice -->
      <div id="base64-status" class="p-12 rounded-12 border border-border dark:border-border-dark bg-surface2 dark:bg-surface2-dark flex items-center gap-8 text-caption font-sans font-semibold text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
          <circle cx="12" cy="12" r="10" /><path d="M12 16v-4M12 8h.01" />
        </svg>
        <span id="b64-status-text">Awaiting action...</span>
      </div>

      <div class="relative flex-grow">
        <textarea
          id="base64-output"
          readonly
          class="w-full h-[220px] rounded-control border border-border dark:border-border-dark bg-code dark:bg-code-dark font-mono text-meta p-12 text-ink dark:text-ink-dark focus:outline-none resize-none"
          placeholder="Result will appear here..."
        ></textarea>
      </div>
    </div>
    
    <div class="mt-16">
      <button
        id="copy-base64-btn"
        class="w-full btn border border-border dark:border-border-dark text-ink dark:text-ink-dark hover:bg-hover dark:hover:bg-hover-dark py-12 rounded-control font-sans font-semibold flex items-center justify-center gap-8 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
        </svg>
        <span id="copy-base64-text">Copy Result</span>
      </button>
    </div>
  </div>

  <!-- Educational Section -->
  <h2 class="text-h2 font-display font-bold text-ink dark:text-ink-dark mb-16">How Base64 Encoding Works</h2>
  <p class="text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-16">
    **Base64** represents binary data in an ASCII string format. It achieves this by dividing every 3 bytes of binary data (24 bits) into 4 groups of 6 bits each. Each 6-bit chunk is then mapped to a specific index in a table of 64 printable characters:
  </p>
  <ul class="list-disc pl-24 text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-16 space-y-4">
    <li><code>A-Z</code> (indices 0-25)</li>
    <li><code>a-z</code> (indices 26-51)</li>
    <li><code>0-9</code> (indices 52-61)</li>
    <li><code>+</code> and <code>/</code> (indices 62-63)</li>
  </ul>
  <p class="text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-24">
    Because Base64 translates 3 bytes of input to 4 bytes of text, the resulting encoded text is always approximately **33% larger** than the source input. The equals sign character (<code>=</code>) is used at the end of the encoded string as padding if the input byte sequence is not a multiple of three.
  </p>

  <h2 class="text-h2 font-display font-bold text-ink dark:text-ink-dark mb-16">UTF-8 Unicode Support</h2>
  <p class="text-body text-ink2 dark:text-ink2-dark leading-relaxed mb-32">
    Standard browser APIs (<code>btoa</code> and <code>atob</code>) only support ASCII characters and throw exceptions if they encounter multi-byte characters like emojis or special international letters. Our encoder uses URI escape buffers to properly encode UTF-8 text strings locally without throwing malformed data error codes.
  </p>

  <!-- Client-side Interactive Script -->
  <script>
    function setupBase64() {
      const inputArea = document.getElementById('base64-input') as HTMLTextAreaElement | null;
      const outputArea = document.getElementById('base64-output') as HTMLTextAreaElement | null;
      const encodeBtn = document.getElementById('encode-btn');
      const decodeBtn = document.getElementById('decode-btn');
      const statusDiv = document.getElementById('base64-status');
      const statusText = document.getElementById('b64-status-text');
      const copyBtn = document.getElementById('copy-base64-btn');
      const copyText = document.getElementById('copy-base64-text');

      if (!inputArea || !outputArea || !encodeBtn || !decodeBtn || !statusDiv || !statusText) return;

      function updateStatus(success: boolean, message: string) {
        statusText!.textContent = message;
        if (success) {
          statusDiv!.className = 'p-12 rounded-12 border border-success/30 bg-success/5 flex items-center gap-8 text-caption font-sans font-semibold text-success';
          statusDiv!.innerHTML = `
            <svg class="h-16 w-16 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>${message}</span>
          `;
        } else {
          statusDiv!.className = 'p-12 rounded-12 border border-danger/30 bg-danger/5 flex items-center gap-8 text-caption font-sans font-semibold text-danger';
          statusDiv!.innerHTML = `
            <svg class="h-16 w-16 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            <span>${message}</span>
          `;
        }
      }

      function encodeText() {
        const val = inputArea!.value;
        if (!val) {
          outputArea!.value = '';
          updateStatus(true, 'Awaiting input...');
          statusDiv!.className = 'p-12 rounded-12 border border-border dark:border-border-dark bg-surface2 dark:bg-surface2-dark flex items-center gap-8 text-caption font-sans font-semibold text-muted';
          return;
        }

        try {
          // Safe Unicode Base64 encoding
          const encoded = btoa(unescape(encodeURIComponent(val)));
          outputArea!.value = encoded;
          updateStatus(true, 'Successfully encoded to Base64.');
        } catch (e: any) {
          outputArea!.value = '';
          updateStatus(false, `Encoding Failed: ${e.message}`);
        }
      }

      function decodeText() {
        const val = inputArea!.value.trim();
        if (!val) {
          outputArea!.value = '';
          updateStatus(true, 'Awaiting input...');
          statusDiv!.className = 'p-12 rounded-12 border border-border dark:border-border-dark bg-surface2 dark:bg-surface2-dark flex items-center gap-8 text-caption font-sans font-semibold text-muted';
          return;
        }

        try {
          // Safe Unicode Base64 decoding
          const decoded = decodeURIComponent(escape(atob(val)));
          outputArea!.value = decoded;
          updateStatus(true, 'Successfully decoded from Base64.');
        } catch (e: any) {
          outputArea!.value = '';
          updateStatus(false, `Decoding Failed: Invalid Base64 structure.`);
        }
      }

      encodeBtn.addEventListener('click', encodeText);
      decodeBtn.addEventListener('click', decodeText);

      // Copy callback
      if (copyBtn && copyText) {
        copyBtn.addEventListener('click', () => {
          const text = outputArea.value;
          if (!text) return;
          navigator.clipboard.writeText(text).then(() => {
            copyText.textContent = 'Copied!';
            copyBtn.classList.add('bg-success/10', 'border-success/30', 'text-success');
            setTimeout(() => {
              copyText.textContent = 'Copy Result';
              copyBtn.classList.remove('bg-success/10', 'border-success/30', 'text-success');
            }, 2000);
          });
        });
      }
    }

    // Set up
    setupBase64();
    document.addEventListener('astro:page-load', setupBase64);
  </script>
</ToolLayout>
