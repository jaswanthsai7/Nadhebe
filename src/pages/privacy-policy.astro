---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Our privacy practices regarding user data on this platform."
>
  <div class="mx-auto max-w-3xl px-24 py-48 sm:py-64">
    <article class="prose-article">
      <h1 class="font-display text-h1 font-bold tracking-tight text-ink dark:text-ink-dark mb-24">Privacy Policy</h1>
      <p class="text-meta font-mono text-muted dark:text-muted-dark mb-24">Last updated: July 2026</p>
      
      <p>
        Your privacy is important to us. This platform does not collect personal identity information, nor do we run cookies, trackers, or dynamic advertisement systems.
      </p>

      <h2>Analytics</h2>
      <p>
        We may use minimal privacy-first analytics providers to measure page views and count visits. No fingerprinting is performed and no data is shared with third parties.
      </p>
    </article>
  </div>
</BaseLayout>
