---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Editorial OS — Contributor Workspace"
  description="Research, draft, edit, and submit technical AI articles directly into our editorial pipeline."
>


  <div class="mx-auto max-w-content px-16 sm:px-24 py-40">
    <!-- Main Solid Glass-styled IDE Container (No blur) -->
    <div class="bg-surface/80 dark:bg-surface-dark/90 border border-border/30 dark:border-border-dark/40 shadow-large rounded-20 p-24 sm:p-32">
      
      <!-- Top Title and Status Header -->
      <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-border/20 dark:border-border-dark/25 pb-24 mb-32 gap-16">
        <div>
          <div class="flex items-center gap-12 mb-8">
            <span class="inline-flex items-center gap-6 rounded-pill bg-accent/15 px-10 py-4 text-xs font-mono font-medium text-accent dark:bg-accent-dark/20 dark:text-accent-dark">
              <span class="h-6 w-6 rounded-pill bg-accent animate-pulse dark:bg-accent-dark"></span>
              Week 1 Milestone
            </span>
            <span class="text-meta text-muted dark:text-muted-dark uppercase tracking-widest text-xs">AI Editorial OS v1.0</span>
          </div>
          <h1 class="font-display text-h1 font-bold text-ink dark:text-ink-dark tracking-tight">AI Contributor Studio</h1>
          <p class="text-caption font-sans text-ink2 dark:text-ink2-dark mt-4">Draft, edit, and submit technical AI content directly to our Git-backed review queue.</p>
        </div>
        <div class="flex items-center gap-12">
          <a href="/" class="inline-flex items-center gap-8 rounded-8 border border-border/30 bg-surface px-16 py-8 text-caption font-sans font-medium text-ink2 hover:bg-hover hover:text-ink dark:border-border-dark dark:bg-surface-dark/35 dark:text-ink2-dark dark:hover:bg-hover-dark dark:hover:text-ink-dark transition-all duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-14 w-14 opacity-60"><path d="m12 19-7-7 7-7M5 12h14"/></svg>
            Back to Site
          </a>
        </div>
      </div>

      <!-- Main IDE Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24 items-start">
        
        <!-- LEFT SIDEBAR: Source & Progress (col span 3) -->
        <aside class="lg:col-span-3 space-y-20">
          
          <!-- Source Card -->
          <div class="rounded-16 border border-border/20 dark:border-border-dark/25 bg-surface2/30 dark:bg-surface-dark/40 p-20">
            <div class="flex items-center gap-8 mb-16">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16 text-accent dark:text-accent-dark"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
              <h2 class="font-display text-h3 font-semibold text-ink dark:text-ink-dark">Source Extraction</h2>
            </div>
            
            <form id="generation-form" class="space-y-16">
              <div>
                <label for="source-url" class="block text-xs font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mb-8">Paste Source URL</label>
                <input
                  type="url"
                  id="source-url"
                  required
                  placeholder="https://youtube.com/watch?v=..."
                  class="w-full rounded-8 border border-border/30 bg-surface2/20 dark:border-border-dark/30 dark:bg-surface-dark/30 px-12 py-10 text-caption text-ink dark:text-ink-dark focus:border-accent dark:focus:border-accent-dark focus:ring-1 focus:ring-accent dark:focus:ring-accent-dark transition-all duration-150"
                />
              </div>

              <div>
                <label for="source-type" class="block text-xs font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mb-8">Source Type</label>
                <select
                  id="source-type"
                  class="w-full rounded-8 border border-border/30 bg-surface2/20 dark:border-border-dark/30 dark:bg-surface-dark/30 px-12 py-10 text-caption text-ink dark:text-ink-dark focus:border-accent dark:focus:border-accent-dark focus:ring-1 focus:ring-accent dark:focus:ring-accent-dark transition-all duration-150"
                >
                  <option value="youtube">YouTube Video URL</option>
                  <option value="github">GitHub Repository</option>
                  <option value="website">Documentation / Blog</option>
                  <option value="raw">Raw Text / Markdown</option>
                </select>
              </div>

              <button
                type="submit"
                id="btn-generate"
                class="w-full inline-flex items-center justify-center gap-8 rounded-8 bg-gradient-to-r from-accent to-indigo-600 hover:from-accent/90 hover:to-indigo-500 py-12 text-caption font-semibold text-white shadow-medium hover:shadow-large transition-all duration-200 cursor-pointer"
              >
                <span>Start Pipeline</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-14 w-14"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </form>
          </div>

          <!-- Research Feed -->
          <div class="rounded-16 border border-border/20 dark:border-border-dark/25 bg-surface2/30 dark:bg-surface-dark/40 p-20">
            <div class="flex items-center justify-between mb-16">
              <div class="flex items-center gap-8">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16 text-accent dark:text-accent-dark"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <h2 class="font-display text-h3 font-semibold text-ink dark:text-ink-dark">Research Feed</h2>
              </div>
              <span id="draft-status" class="text-meta text-xs text-muted dark:text-muted-dark uppercase tracking-widest font-mono">Idle</span>
            </div>
            
            <div class="space-y-16" id="research-feed">
              <p class="text-caption font-sans text-muted dark:text-muted-dark italic">No job queued. Paste a URL above to begin.</p>
            </div>
          </div>
        </aside>

        <!-- CENTER PANES: IDE Workspace Editor (col span 6) -->
        <main class="lg:col-span-6 space-y-20">
          <div class="rounded-16 border border-border/20 dark:border-border-dark/25 bg-surface dark:bg-surface-dark shadow-large overflow-hidden">
            <!-- IDE Toolbar -->
            <div class="flex items-center justify-between border-b border-border/20 dark:border-border-dark/20 px-20 py-12 bg-surface2/40 dark:bg-surface2-dark/30">
              <div class="flex items-center gap-8">
                <button id="tab-editor" class="px-12 py-6 rounded-6 text-caption font-medium bg-surface/80 dark:bg-surface-dark/80 text-ink dark:text-ink-dark border border-border/30 dark:border-border-dark/30 transition-all duration-150 cursor-pointer shadow-subtle">Editor</button>
                <button id="tab-split" class="px-12 py-6 rounded-6 text-caption font-medium text-ink2 dark:text-ink2-dark hover:bg-hover/40 hover:text-ink dark:hover:bg-hover-dark/40 dark:hover:text-ink-dark transition-all duration-150 cursor-pointer">Split View</button>
                <button id="tab-preview" class="px-12 py-6 rounded-6 text-caption font-medium text-ink2 dark:text-ink2-dark hover:bg-hover/40 hover:text-ink dark:hover:bg-hover-dark/40 dark:hover:text-ink-dark transition-all duration-150 cursor-pointer">Live Preview</button>
              </div>
              <div class="flex items-center gap-12">
                <div class="flex gap-6">
                  <span class="h-8 w-8 rounded-pill bg-danger-dark opacity-40"></span>
                  <span class="h-8 w-8 rounded-pill bg-rating-gold opacity-40"></span>
                  <span class="h-8 w-8 rounded-pill bg-success-dark opacity-40"></span>
                </div>
              </div>
            </div>

            <!-- Workspace Textareas -->
            <div id="editor-workspace" class="grid grid-cols-1 gap-0 h-[580px]">
              <!-- Left Pane (Editor) -->
              <div id="pane-editor" class="flex flex-col h-full bg-surface2/10 dark:bg-surface-dark/20">
                <textarea
                  id="markdown-textarea"
                  placeholder="# Your generated markdown will load here..."
                  class="w-full flex-grow p-24 font-mono text-caption text-ink dark:text-ink-dark bg-transparent resize-none focus:outline-none overflow-y-auto leading-relaxed border-0 focus:ring-0"
                ></textarea>
              </div>

              <!-- Right Pane (HTML Live Preview) -->
              <div id="pane-preview" class="hidden border-l border-border/20 dark:border-border-dark/25 p-24 overflow-y-auto bg-surface/90 dark:bg-surface-dark/95">
                <div id="rendered-content" class="prose-article">
                  <p class="text-caption font-sans text-muted dark:text-muted-dark italic">Your preview will be compiled and displayed here.</p>
                </div>
              </div>
            </div>
          </div>
        </main>

        <!-- RIGHT SIDEBAR: Metrics & GitHub Submission (col span 3) -->
        <aside class="lg:col-span-3 space-y-20">
          
          <!-- Metrics Widgets -->
          <div class="rounded-16 border border-border/20 dark:border-border-dark/25 bg-surface2/30 dark:bg-surface-dark/40 p-20">
            <h2 class="font-display text-h3 font-semibold text-ink dark:text-ink-dark mb-16">Calculated Metrics</h2>
            
            <div class="grid grid-cols-2 gap-12 mb-16">
              <div class="bg-surface/50 dark:bg-surface-dark/50 border border-border/10 p-12 rounded-12 text-center">
                <p class="text-meta text-xs text-muted dark:text-muted-dark uppercase tracking-wider mb-4">Word Count</p>
                <p id="metric-wordcount" class="text-h2 font-display font-semibold text-ink dark:text-ink-dark">0</p>
              </div>
              <div class="bg-surface/50 dark:bg-surface-dark/50 border border-border/10 p-12 rounded-12 text-center">
                <p class="text-meta text-xs text-muted dark:text-muted-dark uppercase tracking-wider mb-4">Reading Time</p>
                <p id="metric-readingtime" class="text-h2 font-display font-semibold text-ink dark:text-ink-dark">0<span class="text-caption font-sans font-medium text-ink2 ml-2">min</span></p>
              </div>
            </div>

            <div class="border-t border-border/10 pt-16 flex items-center justify-between">
              <span class="text-caption font-sans text-ink2 dark:text-ink2-dark">Heading Hierarchy:</span>
              <span id="metric-heading-status" class="inline-flex items-center gap-6 rounded-pill bg-danger/10 px-10 py-4 text-xs font-mono font-medium text-danger dark:bg-danger-dark/15 dark:text-danger-dark">
                No H1 Found
              </span>
            </div>
          </div>

          <!-- Submission Card -->
          <div class="rounded-16 border border-border/20 dark:border-border-dark/25 bg-surface2/30 dark:bg-surface-dark/40 p-20">
            <h2 class="font-display text-h3 font-semibold text-ink dark:text-ink-dark mb-16">Submission Panel</h2>
            
            <form id="submission-form" class="space-y-16">
              <div>
                <label for="author-name" class="block text-xs font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mb-8">Contributor Name</label>
                <input
                  type="text"
                  id="author-name"
                  required
                  placeholder="e.g. Alice Chen"
                  class="w-full rounded-8 border border-border/30 bg-surface/50 dark:bg-surface-dark/50 px-12 py-10 text-caption text-ink dark:text-ink-dark focus:border-accent dark:focus:border-accent-dark focus:ring-1 focus:ring-accent dark:focus:ring-accent-dark transition-all duration-150"
                />
              </div>

              <div>
                <label for="article-category" class="block text-xs font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mb-8">Target Category</label>
                <select
                  id="article-category"
                  class="w-full rounded-8 border border-border/30 bg-surface/50 dark:bg-surface-dark/50 px-12 py-10 text-caption text-ink dark:text-ink-dark focus:border-accent dark:focus:border-accent-dark focus:ring-1 focus:ring-accent dark:focus:ring-accent-dark transition-all duration-150"
                >
                  <option value="tutorials">Tutorials</option>
                  <option value="news">AI News</option>
                  <option value="youtube-articles">YouTube Articles</option>
                  <option value="tool-reviews">Tool Reviews</option>
                  <option value="prompts">Prompts</option>
                  <option value="comparisons">Comparisons</option>
                  <option value="best-practices">Best Practices</option>
                  <option value="use-cases">Use Cases</option>
                  <option value="tools">Tools</option>
                  <option value="guides">Guides</option>
                  <option value="frameworks">Frameworks</option>
                  <option value="case-studies">Case Studies</option>
                </select>
              </div>

              <button
                type="submit"
                id="btn-submit"
                disabled
                class="w-full inline-flex items-center justify-center gap-8 rounded-8 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 py-12 text-caption font-semibold text-white shadow-medium hover:shadow-large transition-all duration-200 cursor-not-allowed opacity-50"
              >
                Submit for Review
              </button>
            </form>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <!-- Client-side Workspace Interactivity -->
  <script is:inline>
    (function() {
      // Configuration
      const API_BASE = 'http://localhost:8787/api/v1';

      // Elements
      const genForm = document.getElementById('generation-form');
      const urlInput = document.getElementById('source-url');
      const typeSelect = document.getElementById('source-type');
      const btnGen = document.getElementById('btn-generate');
      
      const researchFeed = document.getElementById('research-feed');
      
      const tabEditor = document.getElementById('tab-editor');
      const tabSplit = document.getElementById('tab-split');
      const tabPreview = document.getElementById('tab-preview');
      const draftStatus = document.getElementById('draft-status');
      
      const workspace = document.getElementById('editor-workspace');
      const paneEditor = document.getElementById('pane-editor');
      const panePreview = document.getElementById('pane-preview');
      
      const textarea = document.getElementById('markdown-textarea');
      const preview = document.getElementById('rendered-content');
      
      const metricWord = document.getElementById('metric-wordcount');
      const metricTime = document.getElementById('metric-readingtime');
      const metricHeading = document.getElementById('metric-heading-status');
      
      const subForm = document.getElementById('submission-form');
      const authorInput = document.getElementById('author-name');
      const catSelect = document.getElementById('article-category');
      const btnSubmit = document.getElementById('btn-submit');

      // State variables
      let currentJobId = null;
      let activeDraftText = '';
      let isGenerating = false;

      // ─── Simple Markdown-to-HTML Parser ───
      function parseMarkdown(md) {
        if (!md) return '<p class="italic text-muted">Empty draft</p>';
        
        // Strip frontmatter blocks
        let cleanMd = md.replace(/^---[\s\S]+?---/, '').trim();
        
        let html = cleanMd
          // Headings
          .replace(/^# (.*?)$/gm, '<h1>$1</h1>')
          .replace(/^## (.*?)$/gm, '<h2>$1</h2>')
          .replace(/^### (.*?)$/gm, '<h3>$1</h3>')
          .replace(/^#### (.*?)$/gm, '<h4>$1</h4>')
          // Code Blocks
          .replace(/```([\s\S]+?)```/g, '<pre class="bg-code px-16 py-12 rounded-8 overflow-x-auto"><code class="font-mono text-xs">$1</code></pre>')
          // Inline code
          .replace(/`([^`]+)`/g, '<code class="bg-code px-6 py-2 rounded-4 text-xs font-mono">$1</code>')
          // Bold
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          // Lists
          .replace(/^\s*-\s+(.*?)$/gm, '<li>$1</li>')
          // Wrap li tags in ul
          .replace(/((?:<li>.*?<\/li>\s*)+)/g, '<ul>$1</ul>')
          // Paragraphs (wrap blank space groups)
          .replace(/^\s*(?!<[a-z/])/gm, '<p>')
          .replace(/(?!<\/[a-z]>)\s*$/gm, '</p>');

        return html;
      }

      // ─── Score and metrics calculations ───
      function updateMetrics(md) {
        const text = md.replace(/^---[\s\S]+?---/, '').trim();
        const wordCount = text ? text.split(/\s+/).length : 0;
        const readingTime = Math.max(1, Math.round(wordCount / 200));
        
        metricWord.textContent = String(wordCount);
        metricTime.textContent = readingTime;

        const hasH1 = /^#\s+.+$/m.test(md) || /^#\s+.+$/m.test(text);
        if (hasH1) {
          metricHeading.textContent = '✓ H1 Present';
          metricHeading.className = 'inline-flex items-center gap-6 rounded-pill bg-success/15 px-10 py-4 text-xs font-mono font-medium text-success dark:bg-success-dark/20 dark:text-success-dark';
        } else {
          metricHeading.textContent = 'No H1 Found';
          metricHeading.className = 'inline-flex items-center gap-6 rounded-pill bg-danger/10 px-10 py-4 text-xs font-mono font-medium text-danger dark:bg-danger-dark/15 dark:text-danger-dark';
        }
      }

      // ─── Workspace Tabs Configuration ───
      function setTabActive(tab) {
        [tabEditor, tabSplit, tabPreview].forEach(t => {
          t.classList.remove('bg-surface/50', 'dark:bg-surface-dark/50', 'text-ink', 'dark:text-ink-dark', 'border', 'border-border/30', 'dark:border-border-dark/30', 'shadow-subtle');
          t.classList.add('text-ink2', 'dark:text-ink2-dark');
        });
        tab.classList.remove('text-ink2', 'dark:text-ink2-dark');
        tab.classList.add('bg-surface/50', 'dark:bg-surface-dark/50', 'text-ink', 'dark:text-ink-dark', 'border', 'border-border/30', 'dark:border-border-dark/30', 'shadow-subtle');
      }

      tabEditor.addEventListener('click', () => {
        setTabActive(tabEditor);
        workspace.classList.remove('grid-cols-2');
        workspace.classList.add('grid-cols-1');
        paneEditor.classList.remove('hidden');
        panePreview.classList.add('hidden');
      });

      tabSplit.addEventListener('click', () => {
        setTabActive(tabSplit);
        workspace.classList.remove('grid-cols-1');
        workspace.classList.add('grid-cols-2');
        paneEditor.classList.remove('hidden');
        panePreview.classList.remove('hidden');
      });

      tabPreview.addEventListener('click', () => {
        setTabActive(tabPreview);
        workspace.classList.remove('grid-cols-2');
        workspace.classList.add('grid-cols-1');
        paneEditor.classList.add('hidden');
        panePreview.classList.remove('hidden');
      });

      // Synchronize editor inputs
      textarea.addEventListener('input', (e) => {
        activeDraftText = e.target.value;
        preview.innerHTML = parseMarkdown(activeDraftText);
        updateMetrics(activeDraftText);
      });

      // ─── Job Generation Pipeline Poller ───
      async function pollJobStatus(jobId) {
        try {
          const res = await fetch(`${API_BASE}/jobs/${jobId}`);
          if (!res.ok) throw new Error('Status poll failed');
          const payload = await res.json();
          const job = payload.data;

          // Render research logs
          researchFeed.innerHTML = job.logs.map(log => {
            const time = new Date(log.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            let prefix = '○';
            let style = 'text-ink2 dark:text-ink2-dark';
            if (log.status === 'Completed') {
              prefix = '✓';
              style = 'text-success dark:text-success-dark font-medium';
            } else if (log.status === 'Failed') {
              prefix = '✗';
              style = 'text-danger dark:text-danger-dark font-medium';
            } else if (log.status === job.status) {
              prefix = '●';
              style = 'text-accent dark:text-accent-dark font-medium animate-pulse';
            }
            return `<div class="flex items-start gap-12 text-caption ${style} border-b border-border/5 pb-10">
              <span class="font-mono mt-2">${prefix}</span>
              <div class="flex-1 min-w-0">
                <p class="font-sans leading-normal text-xs">${log.message}</p>
                <time class="text-xs opacity-50 block font-mono mt-2">${time}</time>
              </div>
            </div>`;
          }).join('');

          draftStatus.textContent = job.status;

          if (job.status === 'Completed') {
            isGenerating = false;
            btnGen.disabled = false;
            btnGen.textContent = 'Start Pipeline';
            
            // Set text & show preview
            activeDraftText = job.markdown || '';
            textarea.value = activeDraftText;
            preview.innerHTML = parseMarkdown(activeDraftText);
            updateMetrics(activeDraftText);

            // Enable submit buttons
            btnSubmit.disabled = false;
            btnSubmit.classList.remove('opacity-50', 'cursor-not-allowed');
            
            // Suggest Category matching source URL configurations
            if (job.sourceType === 'youtube') {
              catSelect.value = 'youtube-articles';
            }
            return;
          }

          if (job.status === 'Failed') {
            isGenerating = false;
            btnGen.disabled = false;
            btnGen.textContent = 'Start Pipeline';
            return;
          }

          // Continue polling
          setTimeout(() => pollJobStatus(jobId), 1500);

        } catch (e) {
          console.error(e);
          isGenerating = false;
          btnGen.disabled = false;
          btnGen.textContent = 'Start Pipeline';
          researchFeed.innerHTML = `<div class="text-caption text-danger dark:text-danger-dark">Error connecting to api-worker. Make sure it is running locally on port 8787.</div>`;
        }
      }

      // Form submission
      genForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (isGenerating) return;

        const url = urlInput.value;
        const sourceType = typeSelect.value;

        isGenerating = true;
        btnGen.disabled = true;
        btnGen.textContent = 'Orchestrating...';
        
        researchFeed.innerHTML = `<div class="flex items-center justify-center py-12">
          <div class="h-16 w-16 animate-spin rounded-pill border-2 border-accent border-t-transparent dark:border-accent-dark"></div>
        </div>`;

        try {
          const res = await fetch(`${API_BASE}/jobs`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url, sourceType })
          });

          if (!res.ok) throw new Error('Failed to create background generation job');
          const payload = await res.json();
          currentJobId = payload.data.id;
          
          pollJobStatus(currentJobId);

        } catch (e) {
          console.error(e);
          isGenerating = false;
          btnGen.disabled = false;
          btnGen.textContent = 'Start Pipeline';
          researchFeed.innerHTML = `<div class="text-caption text-danger dark:text-danger-dark font-sans leading-relaxed">
            Connection Failed: Could not contact local Worker API.<br/>
            Make sure wrangler server is active on port 8787: <br/>
            <code>cd api-worker && npx wrangler dev</code>
          </div>`;
        }
      });

      // ─── Submission to GitHub Issues ───
      subForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const author = authorInput.value;
        const category = catSelect.value;
        const text = textarea.value;

        if (!text) {
          alert('Markdown editor is empty! Generate a draft or write something first.');
          return;
        }

        btnSubmit.disabled = true;
        btnSubmit.textContent = 'Submitting...';

        // Extract title & slug from draft or fallback
        const titleMatch = text.match(/^#\s+(.+)$/m);
        const title = titleMatch ? titleMatch[1].trim() : 'AI Draft Article Submission';
        const slug = title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

        const computedMetrics = {
          wordCount: text.split(/\s+/).length,
          readingTime: Math.max(1, Math.round(text.split(/\s+/).length / 200)),
          headingStructureOk: /^#\s+.+$/m.test(text)
        };

        const payload = {
          title,
          slug,
          category,
          author,
          sourceUrl: urlInput.value || 'https://example.com/source',
          markdown: text,
          computedMetrics,
          aiInsights: {
            confidence: 0.94,
            factCheckSummary: 'Factual specs audited'
          }
        };

        try {
          const res = await fetch(`${API_BASE}/issues`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!res.ok) throw new Error('Submission to issues pipeline failed');
          const dataPayload = await res.json();
          const submission = dataPayload.data;

          alert(`✓ Submission Successful!\nCreated GitHub Issue #${submission.issueNumber}`);
          btnSubmit.textContent = 'Submitted ✓';
          
        } catch (err) {
          console.error(err);
          alert('Submission failed. Check api-worker execution logs.');
          btnSubmit.disabled = false;
          btnSubmit.textContent = 'Submit for Review';
        }
      });

    })();
  </script>
</BaseLayout>
