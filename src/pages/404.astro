---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found"
  description="The page you requested could not be found."
>
  <div class="mx-auto flex min-h-[70vh] max-w-3xl items-center justify-center px-6 py-64">
    <article class="text-center">
      <p class="text-meta font-semibold uppercase tracking-[0.3em] text-accent dark:text-accent-dark">
        Error 404
      </p>

      <h1 class="mt-16 text-display font-bold tracking-tight text-ink dark:text-ink-dark">
        Page Not Found
      </h1>

      <p class="mt-24 text-body text-ink2 dark:text-ink2-dark">
        Sorry, the page you're looking for doesn't exist, has been moved,
        or the URL may be incorrect.
      </p>

      <div class="mt-32 flex flex-wrap justify-center gap-16">
        <a href="/" class="btn-primary">
          Home
        </a>

        <a href="/tutorials" class="btn-secondary">
          Browse Tutorials
        </a>
      </div>

      <div class="mt-48 border-t border-border pt-32 dark:border-border-dark">
        <p class="text-meta text-muted dark:text-muted-dark">
          If you believe this is an error, try navigating from the homepage or
          searching for the topic you're looking for.
        </p>
      </div>
    </article>
  </div>
</BaseLayout>