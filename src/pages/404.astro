---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Page Not Found"
  description="The page you requested could not be found."
>
  <div class="mx-auto flex min-h-[70vh] max-w-3xl items-center justify-center px-6 py-16">
    <article class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-600">
        Error 404
      </p>

      <h1 class="mt-4 text-5xl font-bold tracking-tight sm:text-6xl">
        Page Not Found
      </h1>

      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
        Sorry, the page you're looking for doesn't exist, has been moved,
        or the URL may be incorrect.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="rounded-lg bg-black px-6 py-3 font-medium text-white transition hover:opacity-90 dark:bg-white dark:text-black"
        >
          Home
        </a>

        <a
          href="/blog"
          class="rounded-lg border border-gray-300 px-6 py-3 font-medium transition hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800"
        >
          Browse Blog
        </a>
      </div>

      <div class="mt-12 border-t border-gray-200 pt-8 dark:border-gray-800">
        <p class="text-sm text-gray-500">
          If you believe this is an error, try navigating from the homepage or
          searching for the topic you're looking for.
        </p>
      </div>
    </article>
  </div>
</BaseLayout>