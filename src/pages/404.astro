---
import Layout from "../layouts/Layout.astro"; // Change this to your actual layout
---

<Layout
  title="404 - Page Not Found"
  description="The page you are looking for could not be found."
>
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <h1 class="text-7xl font-bold">404</h1>

    <h2 class="mt-4 text-2xl font-semibold">
      Page Not Found
    </h2>

    <p class="mt-3 max-w-lg text-gray-500">
      Sorry, the page you're looking for doesn't exist or may have been moved.
    </p>

    <div class="mt-8 flex gap-4">
      <a
        href="/"
        class="rounded-xl bg-black px-6 py-3 text-white hover:opacity-90"
      >
        Go Home
      </a>

      <a
        href="/blog"
        class="rounded-xl border px-6 py-3 hover:bg-gray-100"
      >
        Browse Blog
      </a>
    </div>
  </main>
</Layout>