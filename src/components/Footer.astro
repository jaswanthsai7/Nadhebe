---
import { SITE } from '@/config';
const year = new Date().getFullYear();

const readLinks = [
  { label: 'Tutorials', href: '/tutorials' },
  { label: 'Videos', href: '/youtube' },
  { label: 'Guides', href: '/guides' },
  { label: 'Comparisons', href: '/comparisons' },
];

const resourceLinks = [
  { label: 'Reviews', href: '/reviews' },
  { label: 'Prompts', href: '/prompts' },
  { label: 'Tools', href: '/tools' },
  { label: 'Frameworks', href: '/frameworks' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Privacy Policy', href: '/privacy-policy' },
];
---

<footer class="mt-64 sm:mt-128 border-t border-border dark:border-border-dark bg-bg dark:bg-bg-dark">

  <!-- Newsletter CTA -->
  <div class="mx-auto max-w-content px-16 sm:px-24 pt-48 sm:pt-64 pb-32 sm:pb-48">
    <div class="rounded-16 border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-24 sm:p-48 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-24">
      <div>
        <p class="font-display text-h3 font-semibold text-ink dark:text-ink-dark">Stay in the loop</p>
        <p class="mt-8 text-caption font-sans text-ink2 dark:text-ink2-dark max-w-sm">One focused essay per week on AI engineering, tools, and workflows. No noise.</p>
      </div>
      <div class="flex flex-col gap-8 w-full sm:w-auto">
        <form data-footer-newsletter class="flex flex-col sm:flex-row gap-8 w-full sm:w-auto">
          <label for="footer-email" class="sr-only">Email address</label>
          <input
            id="footer-email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="input max-w-[280px]"
          />
          <button type="submit" class="btn-primary shrink-0">Subscribe</button>
        </form>
        <p data-footer-status class="text-xs font-sans text-muted dark:text-muted-dark" role="status"></p>
      </div>
    </div>
  </div>

  <!-- Footer Grid -->
  <div class="mx-auto max-w-content px-16 sm:px-24 pb-48 sm:pb-64">
    <div class="grid grid-cols-2 gap-32 sm:grid-cols-4">

      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="flex items-center gap-8 font-display text-h3 font-semibold text-ink dark:text-ink-dark">
          <img src="/favicon.png" alt="" width="20" height="20" class="h-20 w-20 rounded-4 object-cover" aria-hidden="true" />
          {SITE.name}
        </a>
        <p class="mt-12 text-caption font-sans text-muted dark:text-muted-dark leading-relaxed max-w-[240px]">{SITE.description}</p>
        <div class="mt-16 flex items-center gap-12">
          <a href="https://www.youtube.com/@Nadhebe" target="_blank" rel="noopener noreferrer" aria-label="YouTube channel" class="text-muted hover:text-ink dark:text-muted-dark dark:hover:text-ink-dark transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
              <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17" />
              <path d="m10 15 5-3-5-3z" />
            </svg>
          </a>
          <a href="https://github.com/jaswanthsai7/Nadhebe" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository" class="text-muted hover:text-ink dark:text-muted-dark dark:hover:text-ink-dark transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <p class="text-meta font-mono font-medium uppercase tracking-wider text-muted dark:text-muted-dark">Read</p>
        <ul class="mt-16 space-y-12">
          {readLinks.map(link => (
            <li><a href={link.href} class="text-caption font-sans text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-meta font-mono font-medium uppercase tracking-wider text-muted dark:text-muted-dark">Resources</p>
        <ul class="mt-16 space-y-12">
          {resourceLinks.map(link => (
            <li><a href={link.href} class="text-caption font-sans text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-meta font-mono font-medium uppercase tracking-wider text-muted dark:text-muted-dark">Company</p>
        <ul class="mt-16 space-y-12">
          {companyLinks.map(link => (
            <li><a href={link.href} class="text-caption font-sans text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-48 flex flex-col-reverse items-start justify-between gap-8 border-t border-border pt-24 dark:border-border-dark sm:flex-row sm:items-center">
      <p class="text-xs font-sans text-muted dark:text-muted-dark">© <span class="font-mono">{year}</span> {SITE.name}. All rights reserved.</p>
      <p class="text-xs font-sans text-muted dark:text-muted-dark">Built with Astro</p>
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-footer-newsletter]');
  const status = document.querySelector('[data-footer-status]');
  const button = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status || !button) return;

    const formData = new FormData(form);
    const email = formData.get('email')?.toString().trim();

    if (!email) {
      status.textContent = 'Please enter a valid email address.';
      status.className = 'text-xs font-sans text-danger dark:text-danger-dark';
      return;
    }

    // Set loading state
    button.disabled = true;
    const originalText = button.textContent;
    button.textContent = 'Subscribing...';
    status.textContent = '';
    status.className = 'text-xs font-sans text-muted dark:text-muted-dark';

    try {
      const apiBase = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787/api/v1';
      const res = await fetch(`${apiBase}/subscribe`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email }),
      });

      const payload = await res.json();

      if (!res.ok) {
        throw new Error(payload.error?.message || 'Subscription failed. Please try again.');
      }

      // Success state
      status.textContent = 'Thanks! Check your inbox to confirm.';
      status.className = 'text-xs font-sans text-success dark:text-success-dark';
      form.reset();
      button.disabled = false;
      button.textContent = originalText;
    } catch (err: any) {
      // Error state
      const errMsg = err.message || '';
      if (errMsg.toLowerCase().includes('already') || errMsg.toLowerCase().includes('exists')) {
        status.textContent = 'Already subscribed!';
        status.className = 'text-xs font-sans text-success dark:text-success-dark';
      } else if (errMsg.toLowerCase().includes('invalid') || errMsg.toLowerCase().includes('email')) {
        status.textContent = 'Invalid email address.';
        status.className = 'text-xs font-sans text-danger dark:text-danger-dark';
      } else {
        status.textContent = errMsg || 'Error. Try again later.';
        status.className = 'text-xs font-sans text-danger dark:text-danger-dark';
      }
      button.disabled = false;
      button.textContent = originalText;
    }
  });
</script>

