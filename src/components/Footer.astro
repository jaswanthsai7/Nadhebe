---
import { SITE } from '@/config';
const year = new Date().getFullYear();
---

<footer class="mt-128 border-t border-border dark:border-border-dark bg-bg dark:bg-bg-dark">
  <div class="mx-auto max-w-6xl px-24 py-48">
    <div class="flex flex-col gap-32 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <p class="font-display text-h3 font-semibold text-ink dark:text-ink-dark">{SITE.name}</p>
        <p class="mt-12 text-body leading-relaxed text-muted dark:text-muted-dark">{SITE.description}</p>
      </div>

      <div class="grid grid-cols-2 gap-32 sm:grid-cols-3">
        <div>
          <p class="text-meta font-sans font-semibold uppercase tracking-wide text-muted dark:text-muted-dark">Read</p>
          <ul class="mt-12 space-y-12 text-body">
            <li><a href="/news" class="text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors">Latest news</a></li>
            <li><a href="/tutorials" class="text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors">AI tutorials</a></li>
          </ul>
        </div>
        <div>
          <p class="text-meta font-sans font-semibold uppercase tracking-wide text-muted dark:text-muted-dark">Studio</p>
          <ul class="mt-12 space-y-12 text-body">
            <li><a href="/about" class="text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors">About</a></li>
            <li><a href="/contact" class="text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="text-meta font-sans font-semibold uppercase tracking-wide text-muted dark:text-muted-dark">Legal</p>
          <ul class="mt-12 space-y-12 text-body">
            <li><a href="/privacy-policy" class="text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors">Privacy policy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-48 flex flex-col-reverse items-start justify-between gap-16 border-t border-border pt-24 text-meta text-muted dark:border-border-dark dark:text-muted-dark sm:flex-row sm:items-center font-sans">
      <p>© <span class="font-mono">{year}</span> {SITE.name}. All rights reserved.</p>
      <p>Built with Astro.</p>
    </div>
  </div>
</footer>
