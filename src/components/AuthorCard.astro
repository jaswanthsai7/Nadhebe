---
interface Props {
  name: string;
  role?: string;
  avatar?: string;
  bio?: string;
  twitter?: string;
  reviewedBy?: string;
  updatedDate?: string;
}
const { name, role, avatar, bio, twitter, reviewedBy, updatedDate } = Astro.props;
---

<div class="card flex flex-col gap-16 p-24 sm:flex-row sm:items-start">
  {avatar && (
    <img
      src={avatar}
      alt={name}
      width="48"
      height="48"
      loading="lazy"
      class="h-48 w-48 shrink-0 rounded-control object-cover"
    />
  )}
  <div>
    <p class="text-body font-semibold text-ink dark:text-ink-dark">{name}</p>
    {role && <p class="text-meta text-muted dark:text-muted-dark">{role}</p>}
    {bio && <p class="mt-8 text-body leading-relaxed text-ink2 dark:text-ink2-dark">{bio}</p>}

    <div class="mt-12 flex flex-wrap items-center gap-x-16 gap-y-4 text-meta text-muted dark:text-muted-dark font-sans">
      {twitter && (
        <a href={twitter} target="_blank" rel="noopener noreferrer" class="hover:text-ink dark:hover:text-ink-dark">
          Follow on X
        </a>
      )}
      {reviewedBy && <span>Reviewed by {reviewedBy}</span>}
      {updatedDate && <span class="font-mono">Updated {updatedDate}</span>}
    </div>
  </div>
</div>
