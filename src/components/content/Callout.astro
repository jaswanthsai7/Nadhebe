---
interface Props {
  type?: 'note' | 'tip' | 'warning' | 'info';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const styles = {
  note: {
    bg: 'bg-surface2/50 border-border text-ink2 dark:bg-surface2-dark/50 dark:border-border-dark dark:text-ink2-dark',
    title: 'text-ink dark:text-ink-dark',
    iconPath: 'M12 16v-4M12 8h.01M22 12a10 10 0 1 1-20 0 10 10 0 0 1 20 0z'
  },
  info: {
    bg: 'bg-accent/5 border-accent/20 text-ink2 dark:text-ink2-dark',
    title: 'text-accent dark:text-accent-dark',
    iconPath: 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z'
  },
  tip: {
    bg: 'bg-success/5 border-success/20 text-ink2 dark:text-ink2-dark',
    title: 'text-success dark:text-success-dark',
    iconPath: 'M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83'
  },
  warning: {
    bg: 'bg-danger/5 border-danger/20 text-ink2 dark:text-ink2-dark',
    title: 'text-danger dark:text-danger-dark',
    iconPath: 'M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01'
  }
};

const current = styles[type] || styles.note;
---

<div class={`my-24 p-16 rounded-12 border ${current.bg}`}>
  <div class="flex items-start gap-12">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`h-20 w-20 shrink-0 mt-1 ${current.title}`}>
      <path d={current.iconPath} />
    </svg>
    <div class="flex-1 min-w-0">
      {title && <p class={`font-sans font-semibold mb-4 text-caption ${current.title}`}>{title}</p>}
      <div class="text-caption font-sans leading-relaxed"><slot /></div>
    </div>
  </div>
</div>
