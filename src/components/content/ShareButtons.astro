---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="share-buttons flex flex-wrap items-center gap-12 py-16 border-y border-border my-32 dark:border-border-dark">
  <span class="text-meta font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark mr-8">Share this post</span>
  
  <!-- Twitter/X -->
  <a
    href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-8 rounded-control border border-border bg-surface hover:bg-hover px-12 py-8 text-meta font-sans font-medium text-ink2 hover:text-ink dark:border-border-dark dark:bg-surface-dark dark:hover:bg-hover dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150"
  >
    <svg class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    <span>X</span>
  </a>

  <!-- Facebook -->
  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-8 rounded-control border border-border bg-surface hover:bg-hover px-12 py-8 text-meta font-sans font-medium text-ink2 hover:text-ink dark:border-border-dark dark:bg-surface-dark dark:hover:bg-hover dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150"
  >
    <svg class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
    <span>Facebook</span>
  </a>

  <!-- LinkedIn -->
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-8 rounded-control border border-border bg-surface hover:bg-hover px-12 py-8 text-meta font-sans font-medium text-ink2 hover:text-ink dark:border-border-dark dark:bg-surface-dark dark:hover:bg-hover dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150"
  >
    <svg class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
    <span>LinkedIn</span>
  </a>

  <!-- Copy Link -->
  <button
    id="copy-link-btn"
    data-url={url}
    class="flex items-center gap-8 rounded-control border border-border bg-surface hover:bg-hover px-12 py-8 text-meta font-sans font-medium text-ink2 hover:text-ink dark:border-border-dark dark:bg-surface-dark dark:hover:bg-hover dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150 cursor-pointer"
  >
    <svg class="h-16 w-16 text-muted dark:text-muted-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
    </svg>
    <span id="copy-btn-text">Copy link</span>
  </button>
</div>

<script>
  const btn = document.getElementById('copy-link-btn');
  const textSpan = document.getElementById('copy-btn-text');
  
  if (btn && textSpan) {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') || window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        textSpan.textContent = 'Copied!';
        btn.classList.add('border-accent', 'bg-accent/10');
        setTimeout(() => {
          textSpan.textContent = 'Copy link';
          btn.classList.remove('border-accent', 'bg-accent/10');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy text: ', err);
      }
    });
  }
</script>
