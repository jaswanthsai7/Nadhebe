---
interface Props {
  prev?: { title: string; url: string };
  next?: { title: string; url: string };
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-16 border-t border-border pt-24 mt-48 dark:border-border-dark">
    {prev ? (
      <a
        href={prev.url}
        class="card group flex flex-col items-start gap-4 p-16 text-left"
      >
        <span class="text-meta font-sans font-medium uppercase tracking-wider text-muted dark:text-muted-dark">← Previous Article</span>
        <span class="text-h3 font-display font-semibold text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{prev.title}</span>
      </a>
    ) : (
      <div class="hidden sm:block"></div>
    )}
    {next && (
      <a
        href={next.url}
        class="card group flex flex-col items-end gap-4 p-16 text-right"
      >
        <span class="text-meta font-sans font-medium uppercase tracking-wider text-muted dark:text-muted-dark">Next Article →</span>
        <span class="text-h3 font-display font-semibold text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{next.title}</span>
      </a>
    )}
  </div>
)}
