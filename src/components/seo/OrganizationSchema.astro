---
const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": new URL('#organization', Astro.site || 'https://nadhebe.pages.dev').toString(),
  "name": "Nadhebe",
  "url": Astro.site || 'https://nadhebe.pages.dev',
  "logo": {
    "@type": "ImageObject",
    "url": new URL('/favicon.png', Astro.site || 'https://nadhebe.pages.dev').toString()
  },
  "sameAs": [
    "https://twitter.com/nadhebe",
    "https://github.com/jaswanthsai7/Nadhebe"
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
