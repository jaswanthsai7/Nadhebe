---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="card p-24">
  <p class="mb-16 flex items-center gap-8 text-meta font-sans font-semibold uppercase tracking-wider text-muted dark:text-muted-dark">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-16 w-16">
      <path d="M12 2v4M12 18v4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M2 12h4M18 12h4M4.9 19.1l2.8-2.8M16.3 7.7l2.8-2.8"></path>
    </svg>
    Key takeaways
  </p>
  <ul class="space-y-12">
    {items.map((item) => (
      <li class="flex gap-12 text-body leading-relaxed text-ink2 dark:text-ink2-dark">
        <span class="mt-8 h-8 w-8 shrink-0 rounded-full bg-accent dark:bg-accent-dark"></span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
