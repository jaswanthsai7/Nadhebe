---
import { getArticleUrl } from '@/utils/content';
import VerdictGauge from './VerdictGauge.astro';

interface Props {
  posts: any[];
  heading?: string;
}
const { posts, heading = 'Related reading' } = Astro.props;
---

{posts.length > 0 && (
  <section aria-labelledby="related-heading" class="not-prose">
    <h2 id="related-heading" class="section-title mb-24">
      {heading}
    </h2>
    <div class="grid gap-16 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a href={getArticleUrl(post)} class="card group block overflow-hidden p-0">
          <div class="relative aspect-video w-full overflow-hidden bg-surface2 dark:bg-surface2-dark">
            <img
              src={post.data.heroImage}
              alt={post.data.heroAlt || post.data.title}
              loading="lazy"
              width="400"
              height="250"
              class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-[1.02]"
            />
            {post.data.rating !== undefined && (
              <div class="absolute bottom-8 right-8 bg-surface dark:bg-surface-dark p-4 rounded-8 shadow-medium border border-border dark:border-border-dark">
                <VerdictGauge score={post.data.rating} size={40} />
              </div>
            )}
          </div>
          <div class="p-20">
            <span class="badge mb-8">{post.data.category}</span>
            <h3 class="font-display text-h4 font-semibold leading-snug text-ink dark:text-ink-dark group-hover:text-accent dark:group-hover:text-accent-dark transition-colors duration-150 line-clamp-2">
              {post.data.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
