---
interface Props {
  headers: string[];
  rows: (string | number)[][];
  caption?: string;
}
const { headers, rows, caption } = Astro.props;
---

<figure class="not-prose overflow-x-auto rounded-12 border border-border dark:border-border-dark">
  <table class="w-full min-w-[480px] border-collapse text-meta font-sans">
    <thead>
      <tr class="bg-surface2 dark:bg-surface2-dark">
        {headers.map((h) => (
          <th class="whitespace-nowrap px-16 py-12 text-left font-medium text-ink dark:text-ink-dark">{h}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr class="border-t border-border dark:border-border-dark">
          {row.map((cell) => (
            <td class="px-16 py-12 text-ink2 dark:text-ink2-dark">
              {typeof cell === 'number' || (typeof cell === 'string' && /^[0-9$.%/-]+$/.test(cell.trim())) ? (
                <span class="font-mono">{cell}</span>
              ) : (
                <span>{cell}</span>
              )}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
  {caption && (
    <figcaption class="border-t border-border px-16 py-12 text-meta font-sans text-muted dark:border-border-dark dark:text-muted-dark">
      {caption}
    </figcaption>
  )}
</figure>
