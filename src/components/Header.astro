---
import { SITE } from '@/config';

const mainNav = [
  { label: 'Tutorials', href: '/tutorials' },
  { label: 'Videos', href: '/youtube' },
  { label: 'Reviews', href: '/reviews' },
  { label: 'Guides', href: '/guides' },
];

const moreNav = [
  { label: 'News', href: '/news' },
  { label: 'Prompts', href: '/prompts' },
  { label: 'Comparisons', href: '/comparisons' },
  { label: 'Best Practices', href: '/best-practices' },
  { label: 'Use Cases', href: '/use-cases' },
  { label: 'Tools', href: '/tools' },
  { label: 'Frameworks', href: '/frameworks' },
  { label: 'Case Studies', href: '/case-studies' },
];
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur-lg dark:border-border-dark dark:bg-bg-dark/80">
  <div class="mx-auto flex h-56 max-w-content items-center justify-between px-24">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-8 font-display text-h3 font-semibold tracking-tight text-ink dark:text-ink-dark">
      <img src="/favicon.png" alt="" width="20" height="20" class="h-20 w-20 rounded-4 object-cover" aria-hidden="true" />
      <span>{SITE.name}</span>
    </a>

    <!-- Desktop Nav -->
    <nav aria-label="Primary" class="hidden items-center gap-6 md:flex">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class="px-12 py-6 text-caption font-sans font-medium text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150 rounded-6"
        >
          {item.label}
        </a>
      ))}

      <!-- More Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-4 px-12 py-6 text-caption font-sans font-medium text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150 rounded-6 cursor-pointer">
          More
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-50">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>
        <div class="absolute right-0 mt-4 w-[200px] origin-top-right rounded-12 border border-border bg-surface p-6 shadow-large opacity-0 scale-95 invisible group-hover:opacity-100 group-hover:scale-100 group-hover:visible transition-all duration-200 dark:border-border-dark dark:bg-surface-dark z-50">
          <div class="flex flex-col">
            {moreNav.map((item) => (
              <a
                href={item.href}
                class="block rounded-8 px-12 py-8 text-caption font-sans font-medium text-ink2 hover:bg-hover hover:text-ink dark:text-ink2-dark dark:hover:bg-hover dark:hover:text-ink-dark transition-colors duration-150"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-8">
      <button
        type="button"
        data-search-trigger
        aria-label="Search articles"
        class="flex h-32 items-center gap-6 rounded-8 border border-border bg-surface px-12 text-caption font-sans text-muted hover:border-ink2/30 hover:text-ink2 dark:border-border-dark dark:bg-surface-dark dark:text-muted-dark dark:hover:border-border-dark dark:hover:text-ink2-dark transition-all duration-150 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-14 w-14">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="hidden sm:inline">Search</span>
        <kbd class="hidden sm:inline rounded-4 border border-border bg-surface2 px-4 py-1 text-xs font-mono text-muted dark:border-border-dark dark:bg-surface2-dark dark:text-muted-dark">⌘K</kbd>
      </button>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-32 w-32 items-center justify-center rounded-8 border border-border text-muted hover:text-ink hover:border-ink2/30 dark:border-border-dark dark:text-muted-dark dark:hover:text-ink-dark dark:hover:border-border-dark transition-all duration-150"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden h-16 w-16">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        class="flex h-32 w-32 items-center justify-center rounded-8 border border-border text-muted hover:text-ink dark:border-border-dark dark:text-muted-dark dark:hover:text-ink-dark transition-colors duration-150 md:hidden"
      >
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-16 w-16">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden h-16 w-16">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-nav" class="hidden border-t border-border dark:border-border-dark bg-bg dark:bg-bg-dark md:hidden">
    <nav aria-label="Mobile navigation" class="mx-auto max-w-content px-24 py-16 space-y-4">
      {[...mainNav, ...moreNav].map((item) => (
        <a
          href={item.href}
          class="block rounded-8 px-12 py-12 text-body font-sans font-medium text-ink2 hover:bg-hover hover:text-ink dark:text-ink2-dark dark:hover:bg-hover dark:hover:text-ink-dark transition-colors duration-150"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-8 border-t border-border dark:border-border-dark">
        <button type="button" data-search-trigger class="w-full text-left rounded-8 px-12 py-12 text-body font-sans font-medium text-ink2 hover:bg-hover hover:text-ink dark:text-ink2-dark dark:hover:bg-hover dark:hover:text-ink-dark transition-colors duration-150 cursor-pointer">
          Search
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const root = document.documentElement;
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('icon-sun');
  const moon = document.getElementById('icon-moon');

  function applyTheme(dark: boolean) {
    root.classList.toggle('dark', dark);
    sun?.classList.toggle('hidden', !dark);
    moon?.classList.toggle('hidden', dark);
  }

  const stored = localStorage.getItem('theme');
  applyTheme(stored ? stored === 'dark' : true);

  toggle?.addEventListener('click', () => {
    const isDark = root.classList.contains('dark');
    applyTheme(!isDark);
    localStorage.setItem('theme', !isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  mobileToggle?.addEventListener('click', () => {
    const isOpen = !mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    mobileToggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
