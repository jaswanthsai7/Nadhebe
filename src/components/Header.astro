---
import { SITE } from '@/config';

const nav = [
  { label: 'News', href: '/news' },
  { label: 'Tutorials', href: '/tutorials' },
  { label: 'Videos', href: '/youtube' },
  { label: 'Reviews', href: '/reviews' },
  { label: 'Prompts', href: '/prompts' },
  { label: 'Comparisons', href: '/comparisons' },
];
---

<header class="sticky top-0 z-40 h-64 border-b border-border bg-bg/80 backdrop-blur-md dark:border-border-dark dark:bg-bg-dark/80">
  <div class="mx-auto flex h-64 max-w-6xl items-center justify-between px-24">
    <a href="/" class="font-display text-h3 font-semibold text-ink dark:text-ink-dark">
      {SITE.name}
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-24 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-meta font-mono font-medium text-ink2 hover:text-ink dark:text-ink2-dark dark:hover:text-ink-dark transition-colors duration-150"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-12">
      <a
        href="/search"
        aria-label="Search articles"
        class="flex h-32 w-32 items-center justify-center rounded-control border border-border text-ink2 hover:bg-hover dark:border-border-dark dark:text-ink2-dark dark:hover:bg-hover transition-colors duration-150"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-16 w-16">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
      
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-32 w-32 items-center justify-center rounded-control border border-border text-ink2 hover:bg-hover dark:border-border-dark dark:text-ink2-dark dark:hover:bg-hover transition-colors duration-200"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="hidden h-16 w-16">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-16 w-16">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const root = document.documentElement;
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('icon-sun');
  const moon = document.getElementById('icon-moon');

  function applyTheme(dark: boolean) {
    root.classList.toggle('dark', dark);
    sun?.classList.toggle('hidden', !dark);
    moon?.classList.toggle('hidden', dark);
  }

  const stored = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  applyTheme(stored ? stored === 'dark' : prefersDark);

  toggle?.addEventListener('click', () => {
    const isDark = root.classList.contains('dark');
    applyTheme(!isDark);
    localStorage.setItem('theme', !isDark ? 'dark' : 'light');
  });
</script>
