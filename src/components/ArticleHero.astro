---
import VerdictGauge from './VerdictGauge.astro';

interface Props {
  category: string;
  title: string;
  description: string;
  readingTime: string;
  publishedDate: string;
  updatedDate?: string;
  authorName: string;
  authorAvatar?: string;
  featuredImage: string;
  featuredImageAlt: string;
  rating?: number;
}

const {
  category,
  title,
  description,
  readingTime,
  publishedDate,
  updatedDate,
  authorName,
  authorAvatar,
  featuredImage,
  featuredImageAlt,
  rating,
} = Astro.props;
---

<!-- Article Hero: Title block first, constrained image second -->
<div class="border-b border-border dark:border-border-dark bg-surface/40 dark:bg-surface-dark/40">
  <header class="mx-auto max-w-2xl px-6 pt-10 pb-6">
    <!-- Category badge -->
    <p class="badge mb-16 inline-flex">{category}</p>

    <!-- Title + verdict gauge (reviews) -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-24">
      {rating !== undefined && (
        <div class="shrink-0">
          <VerdictGauge score={rating} size={80} />
        </div>
      )}
      <div class="flex-1 min-w-0">
        <h1 class="font-display text-h1 sm:text-display font-bold text-ink dark:text-ink-dark leading-tight">
          {title}
        </h1>
        <p class="mt-16 text-body leading-relaxed text-ink2 dark:text-ink2-dark max-w-2xl">
          {description}
        </p>
      </div>
    </div>

    <!-- Meta row: author · date · reading time -->
    <div class="mt-24 flex flex-wrap items-center gap-x-16 gap-y-8 text-meta text-muted dark:text-muted-dark font-sans border-t border-border dark:border-border-dark pt-16">
      <div class="flex items-center gap-8 text-ink2 dark:text-ink2-dark font-medium">
        {authorAvatar && (
          <img
            src={authorAvatar}
            alt={authorName}
            width="28"
            height="28"
            class="h-28 w-28 rounded-pill object-cover ring-2 ring-border dark:ring-border-dark"
          />
        )}
        <span>{authorName}</span>
      </div>
      <span aria-hidden="true" class="text-border dark:text-border-dark">·</span>
      <time datetime={publishedDate} class="font-mono">{publishedDate}</time>
      {updatedDate && (
        <>
          <span aria-hidden="true" class="text-border dark:text-border-dark">·</span>
          <span>Updated <time datetime={updatedDate} class="font-mono">{updatedDate}</time></span>
        </>
      )}
      <span aria-hidden="true" class="text-border dark:text-border-dark">·</span>
      <span class="font-mono">{readingTime}</span>
    </div>
  </header>
</div>

<!-- Featured image: constrained, with rounded corners and subtle border -->
{rating === undefined && featuredImage && (
  <div class="mx-auto max-w-2xl px-6 mt-6 mb-2">
    <div class="overflow-hidden rounded-card border border-border dark:border-border-dark shadow-card dark:shadow-none" style="max-height: 420px;">
      <img
        src={featuredImage}
        alt={featuredImageAlt}
        width="1200"
        height="630"
        class="w-full object-cover"
        style="max-height: 420px; object-position: center top;"
        fetchpriority="high"
      />
    </div>
  </div>
)}
